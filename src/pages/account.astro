---
import Base from '../layouts/Base.astro';
import AccountPanel from '../components/AccountPanel.svelte';
---
<Base title="Account — ADE Showdown">
  <article class="account-page">
    <p class="account-page__eyebrow">Account</p>
    <h2>Manage your ADE Showdown data</h2>
    <p>Export your saved ratings or delete your account and all ratings.</p>
    <AccountPanel client:load />
  </article>
</Base>

<style>
  .account-page { max-width: 820px; margin: 0 auto; }
  .account-page__eyebrow { margin: 0 0 8px; color: var(--accent); text-transform: uppercase; letter-spacing: 0.18em; font: 700 0.75rem var(--font-display); }
  h2 { margin: 0 0 12px; font: 900 clamp(2rem, 5vw, 3rem)/1 var(--font-display); text-transform: uppercase; }
  p { color: var(--fg-soft); }
</style>
