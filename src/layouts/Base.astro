---
import AuthButton from '../components/AuthButton.svelte';
import ProgressNudge from '../components/ProgressNudge.svelte';
import { RATABLE_FEATURES } from '../lib/ratable-features';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const DEFAULT_TITLE = 'ADE Arena — ADE & coding-agent orchestrators compared';
const DEFAULT_DESCRIPTION =
  'Side-by-side comparison of Agentic Development Environments (ADE) and coding-agent orchestrators — Conductor, Vibe Kanban, Claude Code Desktop, T3 Code and more.';

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  image = '/og-image.png',
  imageAlt = 'ADE Arena — Agentic Dev Environments & orchestrators, scored side by side.',
} = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCompareActive = pathname === '/' || pathname.startsWith('/compare');
const isRateActive = pathname.startsWith('/rate');

// `Astro.site` is configured in astro.config.mjs and gives an absolute URL
// for canonical / og:url. Falls back to the request URL in dev where
// Astro.site is set but the local port differs — that's fine, social
// crawlers only hit production.
const canonicalUrl = new URL(pathname, Astro.site ?? Astro.url).toString();
const absoluteImage = new URL(image, Astro.site ?? Astro.url).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Icons / PWA manifest -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#140807" />

    <!-- Open Graph (shared previews on Slack, LinkedIn, Discord, iMessage…) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ADE Arena" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@fcamblor" />
    <meta name="twitter:creator" content="@fcamblor" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;700;900&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to comparison</a>
    <header class="site-header">
      <div class="site-header__inner">
        <div class="brand">
          <p class="brand__kicker">
            <span class="brand__mark">
              <svg class="brand__icon" viewBox="0 0 64 64" aria-hidden="true">
                <line x1="32" y1="2" x2="32" y2="8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                <circle cx="32" cy="3.5" r="2" fill="currentColor" />
                <rect x="6" y="10" width="52" height="44" rx="10" fill="none" stroke="currentColor" stroke-width="3" />
                <g stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none">
                  <line x1="12" y1="36" x2="18" y2="24" />
                  <polyline points="22,24 27,30 22,36" />
                  <polyline points="42,24 37,30 42,36" />
                  <line x1="46" y1="36" x2="52" y2="24" />
                </g>
                <text x="32" y="50" text-anchor="middle" font-family="ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace" font-size="10" font-weight="700" font-style="italic" fill="currentColor">vs</text>
              </svg>
              <span>ADE&nbsp;Arena</span>
            </span>
          </p>
          <h1 class="brand__title">
            Agentic Dev Environments &amp; orchestrators,<br />scored side by side.
          </h1>
          <p class="brand__tagline">
            An opinionated, feature-by-feature comparison of the tools that run coding agents
            for you — Conductor, Vibe Kanban, Claude Code Desktop, t3.codes and friends.
            Updated as the field moves.
          </p>
          <nav class="primary-nav" aria-label="Primary">
            <a
              href="/"
              class:list={['primary-nav__tab', { 'is-active': isCompareActive }]}
              aria-current={isCompareActive ? 'page' : undefined}
            >
              <span class="primary-nav__label">Compare</span>
              <span class="primary-nav__hint">side-by-side scores</span>
            </a>
            <a
              href="/rate"
              class:list={['primary-nav__tab', { 'is-active': isRateActive }]}
              aria-current={isRateActive ? 'page' : undefined}
            >
              <span class="primary-nav__label">Rate features</span>
              <span class="primary-nav__hint">weight what you value</span>
            </a>
          </nav>
        </div>
        <div class="site-header__utility">
          <AuthButton client:load />
        </div>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <ProgressNudge total={RATABLE_FEATURES.length} client:idle />
    <footer class="site-footer">
      <div class="site-footer__inner">
        <p class="site-footer__credit">
          A side project by
          <a href="https://github.com/fcamblor" target="_blank" rel="noreferrer">Frédéric&nbsp;Camblor</a>
          (<span aria-hidden="true">❤️</span> support me with
          <a href="https://github.com/sponsors/fcamblor" target="_blank" rel="noreferrer">GitHub Sponsors</a>).
          <br />
          Source &amp; data on
          <a href="https://github.com/fcamblor/ade-arena" target="_blank" rel="noreferrer">github.com/fcamblor/ade-arena</a>.
        </p>
        <p class="site-footer__contrib">
          Spotted something wrong? Got a tool to add?
          <a href="https://github.com/fcamblor/ade-arena/pulls" target="_blank" rel="noreferrer">Open a PR</a>.
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        color-scheme: dark;

        /* Neutrals — charcoal tinted very slightly toward brand red (hue 25) */
        --bg:           oklch(0.16 0.012 25);
        --bg-elev:      oklch(0.20 0.014 25);
        --bg-row:       oklch(0.22 0.014 25);
        --bg-row-alt:   oklch(0.205 0.013 25);
        --bg-sticky:    oklch(0.18 0.013 25);
        --surface:      oklch(0.24 0.014 25);

        --fg:           oklch(0.95 0.012 80);
        --fg-soft:      oklch(0.82 0.015 70);
        --fg-muted:     oklch(0.62 0.018 60);
        --fg-faint:     oklch(0.48 0.020 50);

        --border:       oklch(0.30 0.018 30);
        --border-soft:  oklch(0.25 0.014 30);
        --border-strong: oklch(0.42 0.022 30);

        /* Brand accents */
        --accent:       oklch(0.66 0.20 28);   /* boxing-corner red */
        --accent-ink:   oklch(0.28 0.10 28);
        --accent-soft:  oklch(0.55 0.14 28);
        --canvas:       oklch(0.88 0.045 85);  /* cream / canvas tape */

        /* Support state cells — muted, no shouting */
        --cell-yes:        oklch(0.30 0.060 150);
        --cell-yes-ink:    oklch(0.86 0.110 145);
        --cell-no:         oklch(0.30 0.075 28);
        --cell-no-ink:     oklch(0.82 0.130 28);
        --cell-partial:    oklch(0.32 0.060 75);
        --cell-partial-ink: oklch(0.86 0.130 85);
        --cell-unknown:    oklch(0.24 0.010 250);
        --cell-unknown-ink: oklch(0.62 0.018 250);

        /* Typography */
        --font-display: 'Big Shoulders Display', 'Arial Narrow', system-ui, sans-serif;
        --font-body:    'Hanken Grotesk', system-ui, sans-serif;

        /* Spacing scale (4pt) */
        --s-1: 4px;
        --s-2: 8px;
        --s-3: 12px;
        --s-4: 16px;
        --s-5: 24px;
        --s-6: 32px;
        --s-7: 48px;
        --s-8: 64px;
        --s-9: 96px;

        --radius-sm: 4px;
        --radius-md: 8px;
        --radius-lg: 14px;

        --shadow-card: 0 1px 0 0 oklch(1 0 0 / 0.02) inset,
                       0 12px 32px -16px oklch(0 0 0 / 0.6);
      }

      * { box-sizing: border-box; }

      html, body { margin: 0; padding: 0; }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--fg);
        line-height: 1.55;
        font-feature-settings: 'ss01', 'cv11';
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-image:
          radial-gradient(1200px 600px at 85% -10%, oklch(0.30 0.08 28 / 0.18), transparent 60%),
          radial-gradient(900px 500px at -10% 0%, oklch(0.30 0.04 60 / 0.10), transparent 60%);
        background-attachment: fixed;
      }

      a {
        color: var(--canvas);
        text-decoration: none;
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
        transition: color .15s ease;
      }
      a:hover, a:focus-visible {
        color: var(--accent);
        text-decoration: underline;
      }

      .skip-link {
        position: absolute;
        top: -100px;
        left: var(--s-3);
        background: var(--accent);
        color: var(--bg);
        padding: var(--s-2) var(--s-4);
        border-radius: var(--radius-sm);
        font-weight: 700;
        z-index: 100;
      }
      .skip-link:focus { top: var(--s-3); }

      /* ===== Site header ===== */
      .site-header {
        position: relative;
        padding: clamp(var(--s-5), 4vw, var(--s-7)) clamp(var(--s-4), 4vw, var(--s-7)) 0;
        max-width: 1480px;
        margin: 0 auto;
      }
      .site-header__inner {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--s-5);
        flex-wrap: wrap;
      }
      .brand { flex: 1 1 auto; min-width: 0; }
      .brand__kicker {
        margin: 0 0 var(--s-4);
        display: inline-flex;
        align-items: center;
        font-family: var(--font-display);
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        font-size: clamp(1rem, 1.6vw, 1.25rem);
        color: var(--fg-muted);
      }
      .brand__mark {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--accent);
        letter-spacing: 0.18em;
        border: 1px solid color-mix(in oklch, var(--accent) 50%, transparent);
        padding: 8px 14px 7px;
        border-radius: var(--radius-md);
        background: color-mix(in oklch, var(--accent) 10%, transparent);
      }
      .brand__icon {
        width: 1.4em;
        height: 1.4em;
        flex-shrink: 0;
        /* Nudge the icon down a hair so its visual centre lines up with the
           x-height of the uppercase label text. */
        transform: translateY(0.04em);
      }
      .brand__title {
        margin: 0;
        font-family: var(--font-display);
        font-weight: 900;
        font-size: clamp(2.2rem, 5vw, 3.2rem);
        line-height: 0.95;
        letter-spacing: -0.005em;
        color: var(--fg);
        text-wrap: balance;
      }
      .brand__tagline {
        margin: var(--s-4) 0 0;
        color: var(--fg-soft);
        font-size: 1.05rem;
        line-height: 1.55;
        max-width: 75ch;
      }

      /* Utility area — top-right cluster (repo + auth) */
      .site-header__utility {
        display: inline-flex;
        align-items: center;
        gap: var(--s-2);
        flex-shrink: 0;
      }
      /* Primary navigation — tab strip under the hero tagline */
      .primary-nav {
        margin: var(--s-6) 0 0;
        display: inline-flex;
        gap: clamp(var(--s-4), 3vw, var(--s-6));
        border-bottom: 1px solid var(--border-soft);
        padding: 0 2px;
        flex-wrap: wrap;
      }
      .primary-nav__tab {
        position: relative;
        display: inline-flex;
        flex-direction: column;
        gap: 2px;
        padding: var(--s-2) 2px var(--s-3);
        color: var(--fg-muted);
        transition: color .15s ease;
      }
      .primary-nav__tab::after {
        content: '';
        position: absolute;
        left: 0;
        right: 0;
        bottom: -1px;
        height: 2px;
        background: transparent;
        transition: background .2s ease;
      }
      .primary-nav__tab:hover,
      .primary-nav__tab:focus-visible {
        color: var(--fg);
        text-decoration: none;
      }
      .primary-nav__tab.is-active {
        color: var(--fg);
      }
      .primary-nav__tab.is-active::after {
        background: var(--accent);
      }
      .primary-nav__label {
        font-family: var(--font-display);
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        font-size: 1rem;
        line-height: 1;
      }
      .primary-nav__hint {
        font-size: 0.75rem;
        color: var(--fg-muted);
        letter-spacing: 0.02em;
        line-height: 1.2;
      }


      /* ===== Main ===== */
      main {
        max-width: 1480px;
        margin: 0 auto;
        padding: clamp(var(--s-5), 3vw, var(--s-6)) clamp(var(--s-4), 4vw, var(--s-7)) var(--s-7);
      }

      /* ===== Footer ===== */
      .site-footer {
        border-top: 1px solid var(--border-soft);
        margin-top: var(--s-8);
      }
      .site-footer__inner {
        max-width: 1480px;
        margin: 0 auto;
        padding: var(--s-5) clamp(var(--s-4), 4vw, var(--s-7));
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: var(--s-3);
        color: var(--fg-muted);
        font-size: 0.875rem;
      }
      .site-footer p { margin: 0; }
      .site-footer a { color: var(--fg-soft); }
      .site-footer a:hover { color: var(--accent); }
      .site-footer__credit { max-width: 80ch; }
      .site-footer__contrib { text-align: right; }

      @media (max-width: 720px) {
        .site-footer__contrib { text-align: left; }
        .site-header__inner { gap: var(--s-4); }
        .primary-nav { width: 100%; gap: var(--s-5); }
        .primary-nav__tab { flex: 1 1 0; }
        .primary-nav__hint { font-size: 0.7rem; }
      }
    </style>
  </body>
</html>
