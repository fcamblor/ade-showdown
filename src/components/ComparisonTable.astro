  .row--feature:hover .cell--no      { background-color: color-mix(in oklch, var(--cell-no) 75%, oklch(0.25 0.018 28)); }
  .row--feature:hover .cell--partial { background-color: color-mix(in oklch, var(--cell-partial) 75%, oklch(0.25 0.018 28)); }

  .cell__glyph {
