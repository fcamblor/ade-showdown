  /* ============ Preview / waiting-for-review columns ============ */
  /* Pending columns are rendered into the table for parity with approved ones,
     but kept out of sight until a viewer opts in via the preview query param.
     We collapse the <col> AND set display:none on the cells so the column
     occupies no space in either dimension. */
  col[data-version-status="waiting-for-review"]:not([data-preview-active]) {
    visibility: collapse;
  }
  [data-version-status="waiting-for-review"]:not([data-preview-active]) {
    display: none;
  }
  /* Approved columns that have been superseded by an active preview for the
     same tool: also hidden, restored if the preview is cleared. */
  [data-version-status="approved"][data-preview-overridden] {
    display: none;
  }
  col[data-version-status="approved"][data-preview-overridden] {
    visibility: collapse;
  }

  .tool__preview-banner {
    margin: var(--s-2) 0 0;
    padding: var(--s-2) var(--s-3);
    display: flex;
    align-items: flex-start;
    gap: var(--s-2);
    border: 1px dashed oklch(0.55 0.16 320);
    border-radius: var(--radius-sm, 6px);
    background: oklch(0.25 0.08 320 / 0.35);
    font-size: 0.7rem;
    line-height: 1.4;
    color: oklch(0.9 0.08 320);
  }
  .tool__preview-banner-tag {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 2px 6px;
    border-radius: 2px;
    background: oklch(0.55 0.16 320);
    color: oklch(0.12 0.02 320);
    line-height: 1.2;
  }
  .tool__preview-banner-text { min-width: 0; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition: none !important; animation: none !important; }
  }
</style>

<script>
  // Read the preview query param (?preview=cursor@3.4.17,docker-agent@1.59.0)
  // and toggle data-preview-active / data-preview-overridden attributes across
  // every element that carries a data-preview-key. Keeping the toggle as a
  // data attribute (rather than a class) means the CSS rules above stay
  // co-located with the rest of the visibility logic.
  (() => {
    const raw = new URLSearchParams(window.location.search).get('preview') ?? '';
    const requested = new Set(
      raw
        .split(',')
        .map((entry) => entry.trim())
        .filter(Boolean),
    );
    if (requested.size === 0) return;

    const overriddenToolIds = new Set<string>();
    for (const key of requested) {
      const [toolId] = key.split('@');
      if (toolId) overriddenToolIds.add(toolId);
    }

    const nodes = document.querySelectorAll<HTMLElement>('[data-preview-key]');
    nodes.forEach((node) => {
      const key = node.dataset.previewKey;
      const status = node.dataset.versionStatus;
      const toolId = node.dataset.toolId;
      if (!key || !toolId) return;
      if (status === 'waiting-for-review' && requested.has(key)) {
        node.setAttribute('data-preview-active', '');
      } else if (status === 'approved' && overriddenToolIds.has(toolId)) {
        // Only override the approved column when a corresponding pending
        // version for the same tool actually exists in the DOM — otherwise a
        // typo in the query param would silently erase the approved column.
        const hasPendingMatch = Array.from(nodes).some(
          (n) =>
            n.dataset.toolId === toolId &&
            n.dataset.versionStatus === 'waiting-for-review' &&
            requested.has(n.dataset.previewKey ?? ''),
        );
        if (hasPendingMatch) node.setAttribute('data-preview-overridden', '');
      }
    });
  })();
</script>
