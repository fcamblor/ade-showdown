---
import { FEATURES, ORCHESTRATORS, isApproved } from '../data';
import type { SupportLevel, FeatureCategory, Feature, Platform, TrackingSourceKind } from '../data/schema';
import Evidence from './Evidence.astro';

// Each orchestrator column carries a stable `<toolId>@<version>` key. The
// preview query param (?preview=tool@version[,tool@version…]) opts a viewer
// into one or more waiting-for-review versions; matching pending columns are
// shown and any approved column for the same toolId is hidden so a single
// "current" column per tool stays visible.
const previewKey = (o: typeof ORCHESTRATORS[number]) => `${o.toolId}@${o.version}`;

const trackingKindLabel: Record<TrackingSourceKind, string> = {
  'release-notes': 'Release notes',
  changelog: 'Changelog',
  blog: 'Blog',
  docs: 'Docs',
  'docs-diff': 'Docs diff',
  rss: 'RSS feed',
  'github-releases': 'GitHub releases',
  'github-commits': 'GitHub commits',
  discord: 'Discord',
  twitter: 'Twitter / X',
  youtube: 'YouTube',
  other: 'Other',
};

const platformLabel: Record<Platform, string> = {
  macos: 'macOS',
  windows: 'Windows',
  linux: 'Linux',
  web: 'Any OS · web',
};
const platformTooltip: Record<Platform, string> = {
  macos: 'Runs on macOS',
  windows: 'Runs on Windows',
  linux: 'Runs on Linux',
  web: 'Browser-based — runs on any OS',
};

const supportLabel: Record<SupportLevel, string> = {
  yes: 'Yes',
  partial: 'Partial',
  no: 'No',
  unknown: 'Unknown',
};
const supportGlyph: Record<SupportLevel, string> = {
  yes: '●',
  partial: '◐',
  no: '○',
  unknown: '?',
};
const categoryLabel: Record<FeatureCategory, string> = {
  workflow: 'Workflow',
  collaboration: 'Collaboration',
  integrations: 'Integrations',
  observability: 'Observability',
  pricing: 'Licensing',
  ux: 'User experience',
  platform: 'Platform',
};
const categoryOrder: FeatureCategory[] = [
  'pricing',
  'workflow',
  'ux',
  'integrations',
  'observability',
  'collaboration',
  'platform',
];

// Features rendered as orchestrator-header flags instead of table rows.
// Data stays in src/data/* (with its sources); only the rendering is hoisted.
const HEADER_FLAG_FEATURE_IDS = new Set<string>(['free-tier', 'oss']);

const grouped = categoryOrder
  .map((cat) => ({
    category: cat,
    features: FEATURES.filter((f) => f.category === cat && !HEADER_FLAG_FEATURE_IDS.has(f.id)),
  }))
  .filter((g) => g.features.length > 0);

const freeTierByTool = ORCHESTRATORS.map(
  (o) => o.features.find((f) => f.featureId === 'free-tier'),
);
const ossByTool = ORCHESTRATORS.map(
  (o) => o.features.find((f) => f.featureId === 'oss'),
);

// A free-tier flag is redundant when pricing already implies free usage.
function showFreeTierFlag(orchIdx: number): boolean {
  const orch = ORCHESTRATORS[orchIdx];
  if (freeTierByTool[orchIdx]?.support !== 'yes') return false;
  return orch.pricing !== 'free' && orch.pricing !== 'freemium' && orch.pricing !== 'oss';
}

// Pricing + license are always rendered as a duo: PAID + CLOSED SOURCE,
// FREE + CLOSED SOURCE, FREEMIUM + CLOSED SOURCE, or FREE + OSS. The pricing
// 'oss' value implies free distribution and is normalized to a FREE pill.
type PricingDisplay = 'free' | 'freemium' | 'paid';
function getPricingDisplay(orchIdx: number): PricingDisplay | null {
  const orch = ORCHESTRATORS[orchIdx];
  if (!orch.pricing) return null;
  if (orch.pricing === 'oss') return 'free';
  return orch.pricing;
}
type LicenseKind = 'oss' | 'closed-source';
function getLicenseKind(orchIdx: number): LicenseKind | null {
  const orch = ORCHESTRATORS[orchIdx];
  if (orch.pricing === 'oss') return 'oss';
  const support = ossByTool[orchIdx]?.support;
  if (support === 'yes') return 'oss';
  if (support === 'no') return 'closed-source';
  return null;
}

function findSupport(toolIndex: number, featureId: string) {
  const orch = ORCHESTRATORS[toolIndex];
  return orch.features.find((f) => f.featureId === featureId);
}

type SupportScore = {
  yes: number;
  partial: number;
  total: number;
};

function scoreFeatures(
  features: Feature[],
  supports: (typeof ORCHESTRATORS)[number]['features'],
): SupportScore {
  return features.reduce(
    (score, feature) => {
      const support = supports.find((sup) => sup.featureId === feature.id)?.support;
      if (support === 'yes') score.yes += 1;
      if (support === 'partial') score.partial += 1;
      return score;
    },
    { yes: 0, partial: 0, total: features.length },
  );
}

const visibleFeatures = grouped.flatMap(({ features }) => features);

// Pre-compute per-category breakdown per orchestrator.
const categoryScores = ORCHESTRATORS.map((o) =>
  Object.fromEntries(
    grouped.map(({ category, features }) => [category, scoreFeatures(features, o.features)]),
  ) as Record<FeatureCategory, SupportScore>,
);
const globalScores = ORCHESTRATORS.map((o) => scoreFeatures(visibleFeatures, o.features));

const toolCount = ORCHESTRATORS.length;
const featureCount = visibleFeatures.length;
---

<section class="comparator" aria-labelledby="comparator-title">
  <header class="comparator__intro">
    <div>
      <p class="comparator__eyebrow">Main event</p>
      <h2 id="comparator-title" class="comparator__title">
        {toolCount}&nbsp;contenders&nbsp;·&nbsp;{featureCount}&nbsp;rounds
      </h2>
      <p class="comparator__lede">
        Every feature, every tool, every verdict. Headers stay pinned — scroll vertically through the card, horizontally through the lineup.
      </p>
    </div>
    <ul class="legend" aria-label="Verdict legend">
      <li><span class="legend__dot legend__dot--yes" aria-hidden="true">●</span>Supported</li>
      <li><span class="legend__dot legend__dot--partial" aria-hidden="true">◐</span>Partial</li>
      <li><span class="legend__dot legend__dot--no" aria-hidden="true">○</span>No</li>
      <li><span class="legend__dot legend__dot--unknown" aria-hidden="true">?</span>Unknown</li>
    </ul>
  </header>

  <div class="table-shell" role="region" aria-label="Comparison table" tabindex="0">
      <table class="grid">
        <colgroup>
          <col class="col--feature" />
          {ORCHESTRATORS.map((o) => (
            <col
              class="col--tool"
              data-preview-key={previewKey(o)}
              data-tool-id={o.toolId}
              data-version-status={isApproved(o) ? 'approved' : 'waiting-for-review'}
            />
          ))}
        </colgroup>

        <thead>
          <tr>
            <th scope="col" class="cell--corner">
              <span class="cell--corner__kicker">Feature</span>
              <span class="cell--corner__hint">vs.</span>
            </th>
            {ORCHESTRATORS.map((o, idx) => {
              const pricingDisplay = getPricingDisplay(idx);
              const licenseKind = getLicenseKind(idx);
              const vd = o.versionDetails;
              const versionTooltip = vd
                ? [vd.buildHash && `(${vd.buildHash})`, vd.buildDate].filter(Boolean).join(' ')
                : undefined;
              const pending = !isApproved(o);
              return (
              <th
                scope="col"
                class="cell--tool"
                data-preview-key={previewKey(o)}
                data-tool-id={o.toolId}
                data-version-status={pending ? 'waiting-for-review' : 'approved'}
              >
                <div class="tool">
                  {/* 1/ Title */}
                  <a class="tool__name" href={o.homepage} target="_blank" rel="noreferrer">{o.toolName}</a>

                  {/* 2/ Global stats */}
                  <div class="tool__row tool__row--score">
                    {(() => {
                      const score = globalScores[idx];
                      return (
                        <div
                          class="score score--global"
                          aria-label={`${score.yes} supported plus ${score.partial} partial out of ${score.total} visible features for ${o.toolName}`}
                        >
                          <span class="score__item score__item--yes">
                            <span class="score__glyph" aria-hidden="true">●</span>
                            <span class="score__value">{score.yes}</span>
                          </span>
                          <span class="score__operator" aria-hidden="true">+</span>
                          <span class="score__item score__item--partial">
                            <span class="score__glyph" aria-hidden="true">◐</span>
                            <span class="score__value">{score.partial}</span>
                          </span>
                          <span class="score__den">/ {score.total}</span>
                        </div>
                      );
                    })()}
                  </div>

                  {/* 3/ Licensing + pricing duo */}
                  <div class="tool__row tool__row--pricing">
                    {pricingDisplay && (
                      o.pricingSource ? (
                        <Evidence
                          variant="inline"
                          refLabel={`${o.toolId.replace(/-/g, ' ')} · pricing`}
                          sourceUrl={o.pricingSource.sourceUrl}
                          sourceExtract={o.pricingSource.sourceExtract}
                          ariaLabel={`Show source for pricing on ${o.toolName}`}
                        >
                          <span class={`tool__pill tool__pill--${pricingDisplay}`}>{pricingDisplay}</span>
                        </Evidence>
                      ) : (
                        <span class={`tool__pill tool__pill--${pricingDisplay}`}>{pricingDisplay}</span>
                      )
                    )}
                    {licenseKind && (
                      ossByTool[idx]?.sourceUrl && ossByTool[idx]?.sourceExtract ? (
                        <Evidence
                          variant="inline"
                          refLabel={`${o.toolId.replace(/-/g, ' ')} · ${licenseKind === 'oss' ? 'oss' : 'closed source'}`}
                          sourceUrl={ossByTool[idx]!.sourceUrl!}
                          sourceExtract={ossByTool[idx]!.sourceExtract!}
                          ariaLabel={`Show source for ${licenseKind === 'oss' ? 'open source' : 'closed source'} on ${o.toolName}`}
                        >
                          <span class={`tool__flag tool__flag--${licenseKind}`}>{licenseKind === 'oss' ? 'oss' : 'closed source'}</span>
                        </Evidence>
                      ) : (
                        <span
                          class={`tool__flag tool__flag--${licenseKind}`}
                          title={licenseKind === 'oss' ? 'Source available under a permissive license' : 'Proprietary — source code is not publicly available'}
                        >{licenseKind === 'oss' ? 'oss' : 'closed source'}</span>
                      )
                    )}
                    {showFreeTierFlag(idx) && (
                      freeTierByTool[idx]?.sourceUrl && freeTierByTool[idx]?.sourceExtract ? (
                        <Evidence
                          variant="inline"
                          refLabel={`${o.toolId.replace(/-/g, ' ')} · free tier`}
                          sourceUrl={freeTierByTool[idx]!.sourceUrl!}
                          sourceExtract={freeTierByTool[idx]!.sourceExtract!}
                          ariaLabel={`Show source for free tier on ${o.toolName}`}
                        >
                          <span class="tool__flag tool__flag--free-tier">
                            <span class="tool__flag-mark" aria-hidden="true">✦</span>
                            <span>free tier</span>
                          </span>
                        </Evidence>
                      ) : (
                        <span
                          class="tool__flag tool__flag--free-tier"
                          title="Free plan usable without a credit card"
                        >
                          <span class="tool__flag-mark" aria-hidden="true">✦</span>
                          <span>free tier</span>
                        </span>
                      )
                    )}
                  </div>

                  {/* 4/ Version + release date */}
                  <div class="tool__row tool__row--version">
                    {versionTooltip ? (
                      <span class="tool__version tool__version--has-tooltip" title={versionTooltip}>v{o.version}</span>
                    ) : (
                      <span class="tool__version">v{o.version}</span>
                    )}
                    {o.releaseDate ? (
                      <span class="tool__release" title={`Released ${o.releaseDate}`}>
                        <span class="tool__release-label">Released</span>
                        <time datetime={o.releaseDate}>{o.releaseDate}</time>
                      </span>
                    ) : (
                      <span class="tool__release tool__release--placeholder" aria-hidden="true">&nbsp;</span>
                    )}
                  </div>

                  {/* 5/ Supported platforms */}
                  <div class="tool__row tool__row--platforms">
                    {o.platforms && o.platforms.length > 0 ? (
                      <ul class="tool__platforms" aria-label="Supported platforms">
                        {o.platforms.map((p) => {
                          const src = o.platformSources?.[p];
                          return (
                            <li class="tool__platform-item">
                              {src ? (
                                <Evidence
                                  variant="inline"
                                  refLabel={`${o.toolId.replace(/-/g, ' ')} · ${p}`}
                                  sourceUrl={src.sourceUrl}
                                  sourceExtract={src.sourceExtract}
                                  ariaLabel={`Show source for ${platformTooltip[p]} on ${o.toolName}`}
                                >
                                  <span class={`tool__platform tool__platform--${p}`}>{platformLabel[p]}</span>
                                </Evidence>
                              ) : (
                                <span class={`tool__platform tool__platform--${p}`} title={platformTooltip[p]}>
                                  {platformLabel[p]}
                                </span>
                              )}
                            </li>
                          );
                        })}
                      </ul>
                    ) : (
                      <span class="tool__platforms-placeholder" aria-hidden="true">&nbsp;</span>
                    )}
                  </div>

                  {/* 6/ Warnings */}
                  <div class="tool__row tool__row--notices">
                    {o.modelRestriction && (
                      <p class="tool__notice tool__notice--models" role="note">
                        <span class="tool__notice-icon" aria-hidden="true">⚠</span>
                        <span class="tool__notice-text">
                          {o.modelRestriction.sourceUrl
                            ? <a href={o.modelRestriction.sourceUrl} target="_blank" rel="noreferrer">{o.modelRestriction.message}</a>
                            : o.modelRestriction.message}
                        </span>
                      </p>
                    )}
                    {o.misc && (
                      <p class="tool__notice" role="note">
                        <span class="tool__notice-icon" aria-hidden="true">⚠</span>
                        <span class="tool__notice-text">
                          {o.misc.sourceUrl
                            ? <a href={o.misc.sourceUrl} target="_blank" rel="noreferrer">{o.misc.message}</a>
                            : o.misc.message}
                        </span>
                      </p>
                    )}
                  </div>

                  {/* 7/ Preview banner — last so it sits at the very bottom of
                       the header, below warnings. */}
                  {pending && (
                    <p class="tool__preview-banner" role="note">
                      <span class="tool__preview-banner-tag">Preview</span>
                      <span class="tool__preview-banner-text">
                        v{o.version} is waiting for review — not yet part of the public dataset.
                      </span>
                    </p>
                  )}
                </div>
              </th>
              );
            })}
          </tr>
        </thead>

        <tbody>
          {grouped.map((group) => (
            <>
              <tr class="row--category">
                <th scope="rowgroup" class="cell--category">
                  <span class="cell--category__label">{categoryLabel[group.category]}</span>
                  <span class="cell--category__count">{group.features.length} feature{group.features.length > 1 ? 's' : ''}</span>
                </th>
                {ORCHESTRATORS.map((o, i) => {
                  const s = categoryScores[i][group.category];
                  return (
                    <td
                      class="cell--category-score"
                      data-preview-key={previewKey(o)}
                      data-tool-id={o.toolId}
                      data-version-status={isApproved(o) ? 'approved' : 'waiting-for-review'}
                      aria-label={`${s.yes} supported plus ${s.partial} partial out of ${s.total} ${categoryLabel[group.category]} features`}
                    >
                      <div class="score score--category">
                        <span class="score__item score__item--yes">
                          <span class="score__glyph" aria-hidden="true">●</span>
                          <span class="score__value">{s.yes}</span>
                        </span>
                        <span class="score__operator" aria-hidden="true">+</span>
                        <span class="score__item score__item--partial">
                          <span class="score__glyph" aria-hidden="true">◐</span>
                          <span class="score__value">{s.partial}</span>
                        </span>
                        <span class="score__den">/ {s.total}</span>
                      </div>
                    </td>
                  );
                })}
              </tr>
              {group.features.map((feature: Feature) => (
                <tr class="row--feature">
                  <th scope="row" class="cell--feature">
                    <div class="feature">
                      <p class="feature__label">{feature.label}</p>
                      <p class="feature__body">{feature.longDescription ?? feature.shortDescription}</p>
                    </div>
                  </th>
                  {ORCHESTRATORS.map((orch, i) => {
                    const s = findSupport(i, feature.id);
                    const level: SupportLevel = s?.support ?? 'unknown';
                    const hasEvidence = !!(s?.sourceUrl && s?.sourceExtract);
                    return (
                      <td
                        class={`cell cell--${level}`}
                        data-support={level}
                        data-preview-key={previewKey(orch)}
                        data-tool-id={orch.toolId}
                        data-version-status={isApproved(orch) ? 'approved' : 'waiting-for-review'}
                      >
                        <span class="cell__glyph" aria-label={supportLabel[level]} role="img">{supportGlyph[level]}</span>
                        {s?.note && <p class="cell__note">{s.note}</p>}
                        {hasEvidence && (
                          <Evidence
                            variant="cell"
                            refLabel={`${orch.toolId.replace(/-/g, ' ')} · ${feature.id.replace(/-/g, ' ')}`}
                            sourceUrl={s!.sourceUrl!}
                            sourceExtract={s!.sourceExtract!}
                            ariaLabel={`Show source for ${feature.label} on ${orch.toolName}`}
                          />
                        )}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
  </div>

  <section class="sources" aria-labelledby="sources-title">
    <header class="sources__head">
      <p class="sources__eyebrow">Reference desk</p>
      <h3 id="sources-title" class="sources__title">Tracking sources</h3>
      <p class="sources__lede">
        Where each vendor publishes news, changelogs, and docs. Used as the starting point when refreshing this dataset for a new release — no need to re-hunt every cycle.
      </p>
    </header>
    <ul class="sources__grid" role="list">
      {ORCHESTRATORS.map((o) => (
        <li
          class="sources__card"
          data-preview-key={previewKey(o)}
          data-tool-id={o.toolId}
          data-version-status={isApproved(o) ? 'approved' : 'waiting-for-review'}
        >
          <h4 class="sources__tool">
            <a href={o.homepage} target="_blank" rel="noreferrer">{o.toolName}</a>
          </h4>
          {o.trackingSources && o.trackingSources.length > 0 ? (
            <ul class="sources__list" role="list">
              {o.trackingSources.map((src) => (
                <li class="sources__item">
                  <span class={`sources__kind sources__kind--${src.kind}`}>{trackingKindLabel[src.kind]}</span>
                  <a class="sources__link" href={src.url} target="_blank" rel="noreferrer">{src.label}</a>
                  {src.notes && <span class="sources__notes">{src.notes}</span>}
                </li>
              ))}
            </ul>
          ) : (
            <p class="sources__empty">No tracking sources registered yet.</p>
          )}
        </li>
      ))}
    </ul>
  </section>
</section>

<style>
  /* ============ Intro ============ */
  .comparator { display: flex; flex-direction: column; gap: var(--s-5); }
  .comparator__intro {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-5);
    flex-wrap: wrap;
  }
  .comparator__eyebrow {
    margin: 0 0 var(--s-2);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
  }
  .comparator__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    letter-spacing: 0.005em;
    color: var(--fg);
    line-height: 1;
  }
  .comparator__lede {
    margin: var(--s-3) 0 0;
    color: var(--fg-soft);
    max-width: 60ch;
  }

  .legend {
    list-style: none;
    margin: 0;
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    background: var(--bg-elev);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4);
    font-size: 0.8rem;
    color: var(--fg-soft);
  }
  .legend li { display: inline-flex; align-items: center; gap: var(--s-2); }
  .legend__dot {
    display: inline-grid;
    place-items: center;
    width: 1.2em;
    font-size: 1.05em;
    line-height: 1;
  }
  .legend__dot--yes      { color: var(--cell-yes-ink); }
  .legend__dot--partial  { color: var(--cell-partial-ink); }
  .legend__dot--no       { color: var(--cell-no-ink); }
  .legend__dot--unknown  { color: var(--cell-unknown-ink); }

  /* ============ Table shell ============ */
  .table-shell {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-elev);
    box-shadow: var(--shadow-card);
    /* Single scrollbar = the page's. No internal scroll container, so sticky
       cells anchor to the viewport itself. */
    overflow: visible;
  }
  .table-shell:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  .grid {
    table-layout: fixed; /* fixed widths => toggling feature details doesn't reflow columns */
    border-collapse: separate;
    border-spacing: 0;
    width: max-content;
    min-width: 100%;
    font-size: 0.9rem;
  }

  /* Column widths — fixed-layout means these are authoritative */
  .col--feature { width: 300px; }
  .col--tool    { width: 200px; }

  /* ============ Cells ============ */
  th, td {
    text-align: left;
    vertical-align: top;
    padding: var(--s-4);
    border-bottom: 1px solid var(--border-soft);
    border-right: 1px solid var(--border-soft);
  }
  td:last-child, th:last-child { border-right: none; }
  tbody tr:last-child td,
  tbody tr:last-child th { border-bottom: none; }

  /* ============ Corner (top-left) ============ */
  .cell--corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 5;
    background: var(--bg-row);
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    font-family: var(--font-display);
    text-transform: uppercase;
    padding: var(--s-4) var(--s-4) var(--s-3);
  }
  .cell--corner__kicker {
    display: block;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--fg);
  }
  .cell--corner__hint {
    display: block;
    margin-top: var(--s-2);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--accent);
    font-weight: 700;
  }

  /* ============ Tool header column ============ */
  .cell--tool {
    position: sticky;
    top: 0;
    z-index: 3;
    background: var(--bg-row);
    border-bottom: 1px solid var(--border);
    padding: var(--s-4) var(--s-3);
  }
  /* When a header cell has an open proof popover, lift it above sibling sticky
     headers so the card isn't clipped by the next column's stacking context. */
  .cell--tool:has(.evidence[open]) { z-index: 6; }
  .cell--corner:has(.evidence[open]) { z-index: 7; }
  .tool { display: flex; flex-direction: column; gap: var(--s-2); position: relative; }
  .tool__name {
    display: block;
    min-height: 2.9rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.45rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--fg);
    letter-spacing: 0.005em;
    margin-top: 2px;
    word-break: break-word;
  }
  .tool__name:hover, .tool__name:focus-visible { color: var(--accent); text-decoration: none; }

  /* Vertically aligned header rows. Every column reserves the same vertical
     space per row — empty placeholders are inserted when a tool is missing
     data — so titles, scores, pricing duos, versions, platforms and warnings
     all line up horizontally across the lineup. */
  .tool__row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .tool__row--score    { min-height: 2rem; }
  .tool__row--pricing  { min-height: 1.5rem; }
  .tool__row--version  {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-height: 2.1rem;
  }
  .tool__row--platforms { min-height: 1.5rem; align-items: flex-start; }
  .tool__row--notices  {
    flex-direction: column;
    align-items: stretch;
    gap: var(--s-2);
