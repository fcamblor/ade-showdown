    .feature { padding: var(--s-3); }
  }

  /* ============ Preview / alternate columns ============ */
  /* Every version of every tool is rendered into the table. The "default"
     column per tool is the latest approved one — visible without any opt-in.
     "alternate" columns (older approved versions and waiting-for-review ones)
     are collapsed until activated through the preview query param or the
     in-page version-switcher dropdown. When an
     alternate is activated for a tool, the default for the same tool is
     overridden so a single column per tool stays visible. */
  col[data-display-mode="alternate"]:not([data-preview-active]) {
    visibility: collapse;
  }
  [data-display-mode="alternate"]:not([data-preview-active]) {
    display: none;
  }
  [data-display-mode="default"][data-preview-overridden] {
    display: none;
  }
  col[data-display-mode="default"][data-preview-overridden] {
    visibility: collapse;
  }

  .tool__preview-banner {
    margin: 0;
    padding: var(--s-2) var(--s-3);
    display: flex;
    align-items: flex-start;
    gap: var(--s-2);
    border: 1px dashed oklch(0.55 0.16 320);
    border-radius: var(--radius-sm, 6px);
    background: oklch(0.25 0.08 320 / 0.35);
    font-size: 0.7rem;
    line-height: 1.4;
    color: oklch(0.9 0.08 320);
  }
  .tool__preview-banner-tag {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 2px 6px;
    border-radius: 2px;
    background: oklch(0.55 0.16 320);
    color: oklch(0.12 0.02 320);
    line-height: 1.2;
  }
  .tool__preview-banner-text { min-width: 0; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after { transition: none !important; animation: none !important; }
  }
</style>

<script>
  // The `?preview=<toolId>@<version>[,…]` query param unlocks one or more
  // waiting-for-review versions: their dropdown option becomes visible and,
  // on initial load, the matching column is shown in place of the default.
  // The dropdown switcher itself is purely client-side — picking a different
  // version toggles DOM attributes only, never touches the URL. That means
  // a previewer can swap back and forth between the unlocked pending version
  // and the latest approved one without losing the preview unlock.
  (() => {
    const QUERY_PARAM = 'preview';

    type NodeState = {
      key: string;
      toolId: string;
      version: string;
      mode: 'default' | 'alternate';
    };

    const nodes = Array.from(
      document.querySelectorAll<HTMLElement>('[data-preview-key]'),
    );
    const nodeStates: Array<{ el: HTMLElement; state: NodeState }> = [];
    for (const el of nodes) {
      const key = el.dataset.previewKey;
      const toolId = el.dataset.toolId;
      const mode = el.dataset.displayMode;
      if (!key || !toolId || (mode !== 'default' && mode !== 'alternate')) continue;
      const version = key.slice(toolId.length + 1);
      nodeStates.push({ el, state: { key, toolId, version, mode } });
    }

    function parseParam(raw: string): Set<string> {
      return new Set(
        raw
          .split(',')
          .map((entry) => entry.trim())
          .filter(Boolean),
      );
    }

    // Parsed once at load and never mutated — represents which pending
    // versions the URL has unlocked. Switching versions in-page doesn't
    // change this set, so a previewer can always swap back to their unlocked
    // version from the dropdown.
    const unlockedKeys = parseParam(
      new URLSearchParams(window.location.search).get(QUERY_PARAM) ?? '',
    );

    // In-memory active selection per tool. Initially populated from the URL
    // (so an `?preview=` link opens straight to the pending column); updated
    // by the dropdown change handler. Missing entry = show the default.
    const activeByTool = new Map<string, string>();
    for (const key of unlockedKeys) {
      const [toolId, version] = key.split('@');
      if (toolId && version) activeByTool.set(toolId, version);
    }

    function apply() {
      // Toggle column visibility based on activeByTool.
      const liveOverrides = new Set<string>();
      for (const { state } of nodeStates) {
        if (
          state.mode === 'alternate' &&
          activeByTool.get(state.toolId) === state.version
        ) {
          liveOverrides.add(state.toolId);
        }
      }
      for (const { el, state } of nodeStates) {
        if (
          state.mode === 'alternate' &&
          activeByTool.get(state.toolId) === state.version
        ) {
          el.setAttribute('data-preview-active', '');
        } else {
          el.removeAttribute('data-preview-active');
        }
        if (state.mode === 'default' && liveOverrides.has(state.toolId)) {
          el.setAttribute('data-preview-overridden', '');
        } else {
          el.removeAttribute('data-preview-overridden');
        }
      }
      // Hide pending dropdown options that the URL hasn't unlocked. Approved
      // options never get hidden — they are public knowledge. If filtering
      // leaves the select with at most one visible option, swap it for the
      // static fallback span so the leftover 1-option dropdown does not hint
      // at the existence of a hidden preview.
      document
        .querySelectorAll<HTMLSelectElement>('.tool__version--switcher')
        .forEach((select) => {
          const toolId = select.dataset.toolId;
          if (!toolId) return;
          for (const opt of Array.from(select.options)) {
            if (opt.dataset.pending !== 'true') continue;
            const key = `${toolId}@${opt.value}`;
            opt.hidden = !unlockedKeys.has(key);
          }
          const visibleCount = Array.from(select.options).filter((o) => !o.hidden).length;
          const fallback = select.nextElementSibling as HTMLElement | null;
          const useFallback = visibleCount <= 1;
          select.hidden = useFallback;
          if (fallback?.classList.contains('tool__version--fallback')) {
            fallback.hidden = !useFallback;
          }
        });
      // Headline contender count: distinct tools currently visible (a tool is
      // visible when its default col is on OR a preview-active col unlocks it).
      const visibleTools = new Set<string>();
      for (const { el, state } of nodeStates) {
        if (state.mode === 'default' || el.hasAttribute('data-preview-active')) {
          visibleTools.add(state.toolId);
        }
      }
      document
        .querySelectorAll<HTMLElement>('[data-tool-count]')
        .forEach((node) => {
          node.textContent = String(visibleTools.size);
        });
    }

    apply();

    // Switcher dropdown — purely client-side. Updates activeByTool then
    // re-applies the DOM state. URL is never touched: the active selection
    // is not bookmarkable, only the preview unlock is.
    document
      .querySelectorAll<HTMLSelectElement>('.tool__version--switcher')
      .forEach((select) => {
        select.addEventListener('change', () => {
          const toolId = select.dataset.toolId;
          const defaultVersion = select.dataset.defaultVersion;
          if (!toolId || !defaultVersion) return;
          const newVersion = select.value;
          if (newVersion === defaultVersion) {
            activeByTool.delete(toolId);
          } else {
            activeByTool.set(toolId, newVersion);
          }
          apply();
        });
      });
  })();
</script>
