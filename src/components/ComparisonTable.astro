---
import { FEATURES, ORCHESTRATORS, ORCHESTRATORS_BY_TOOL, isApproved, isDefaultVisible } from '../data';
import type { SupportLevel, FeatureCategory, Feature, Platform, TrackingSourceKind, ModelIntegrationKind } from '../data/schema';
import Evidence from './Evidence.astro';

// Each orchestrator column carries a stable `<toolId>@<version>` key. The
// preview query param (?preview=tool@ver[,tool@ver…]) unlocks one or more
// waiting-for-review versions: their dropdown option becomes visible and,
// on initial load, the matching alternate column is shown in place of the
// default. The dropdown switcher is otherwise purely client-side — picking
// a version toggles DOM attributes only, the URL is never rewritten. That
// keeps `?preview=` semantically focused on PR-review sharing.
const previewKey = (o: typeof ORCHESTRATORS[number]) => `${o.toolId}@${o.version}`;
const displayMode = (o: typeof ORCHESTRATORS[number]) =>
  isDefaultVisible(o) ? 'default' : 'alternate';
const defaultVersionFor = (toolId: string) => {
  const versions = ORCHESTRATORS_BY_TOOL[toolId];
  return versions.find(isDefaultVisible)?.version ?? versions[0]?.version ?? '';
};

const trackingKindLabel: Record<TrackingSourceKind, string> = {
  'release-notes': 'Release notes',
  changelog: 'Changelog',
  blog: 'Blog',
  docs: 'Docs',
  'docs-diff': 'Docs diff',
  rss: 'RSS feed',
  'github-releases': 'GitHub releases',
  'github-commits': 'GitHub commits',
  discord: 'Discord',
  twitter: 'Twitter / X',
  youtube: 'YouTube',
  other: 'Other',
};

// Short, scannable labels for each model-integration kind. Full meaning is
// surfaced via the title tooltip and the Evidence popover when present.
const integrationKindLabel: Record<ModelIntegrationKind, string> = {
  'provider-sdk': 'SDK',
  'cli-subprocess': 'CLI',
  'app-server-jsonrpc': 'JSON-RPC',
  'acp': 'ACP',
  'openai-compatible-api': 'OpenAI API',
  'mcp': 'MCP',
  'other': 'Other',
};
const integrationKindTooltip: Record<ModelIntegrationKind, string> = {
  'provider-sdk': 'Vendor SDK — calls the provider library directly',
  'cli-subprocess': 'CLI subprocess — wraps an existing coding-agent CLI (e.g. `claude -p`, `codex …`)',
  'app-server-jsonrpc': 'App-server JSON-RPC — long-running headless agent driven over JSON-RPC',
  'acp': 'Agent Client Protocol — standardized agent-to-host protocol',
  'openai-compatible-api': 'OpenAI-compatible HTTP API — any endpoint speaking the OpenAI schema',
  'mcp': 'Model Context Protocol server exposing the model',
  'other': 'Other integration mechanism',
};

const platformLabel: Record<Platform, string> = {
  macos: 'macOS',
  windows: 'Windows',
  linux: 'Linux',
  web: 'Any OS · web',
};
const platformTooltip: Record<Platform, string> = {
  macos: 'Runs on macOS',
  windows: 'Runs on Windows',
  linux: 'Runs on Linux',
  web: 'Browser-based — runs on any OS',
};

const supportLabel: Record<SupportLevel, string> = {
  yes: 'Yes',
  partial: 'Partial',
  no: 'No',
  unknown: 'Unknown',
};
const supportGlyph: Record<SupportLevel, string> = {
  yes: '●',
  partial: '◐',
  no: '○',
  unknown: '?',
};
const categoryLabel: Record<FeatureCategory, string> = {
  workflow: 'Workflow',
  collaboration: 'Collaboration',
  integrations: 'Integrations',
  observability: 'Observability',
  pricing: 'Licensing',
  ux: 'User experience',
  platform: 'Platform',
};
const categoryOrder: FeatureCategory[] = [
  'pricing',
  'workflow',
  'ux',
  'integrations',
  'observability',
  'collaboration',
  'platform',
];

const grouped = categoryOrder
  .map((cat) => ({
    category: cat,
    features: FEATURES.filter((f) => f.category === cat),
  }))
  .filter((g) => g.features.length > 0);

// Pricing + codebase are always rendered as a duo: PAID + PROPRIETARY,
// FREE + PROPRIETARY, FREEMIUM + PROPRIETARY, or FREE + OPEN SOURCE. The
// pricing 'oss' value implies free distribution and is normalized to a
// FREE pill.
type PricingDisplay = 'free' | 'freemium' | 'paid';
function getPricingDisplay(orchIdx: number): PricingDisplay | null {
  const orch = ORCHESTRATORS[orchIdx];
  if (!orch.pricing) return null;
  if (orch.pricing === 'oss') return 'free';
  return orch.pricing;
}

// Map the data value to its presentational CSS modifier + label. The
// visual identifiers `--oss` / `--closed-source` are kept stable to avoid
// reshuffling styles when the data model evolves.
const codebaseFlag = {
  'open-source': { modifier: 'oss', label: 'oss', title: 'Source available under a permissive license' },
  proprietary: { modifier: 'closed-source', label: 'closed source', title: 'Proprietary — source code is not publicly available' },
} as const;

function findSupport(toolIndex: number, featureId: string) {
  const orch = ORCHESTRATORS[toolIndex];
  return orch.features.find((f) => f.featureId === featureId);
}

type SupportScore = {
  yes: number;
  partial: number;
  total: number;
};

function scoreFeatures(
  features: Feature[],
  supports: (typeof ORCHESTRATORS)[number]['features'],
): SupportScore {
  return features.reduce(
    (score, feature) => {
      const support = supports.find((sup) => sup.featureId === feature.id)?.support;
      if (support === 'yes') score.yes += 1;
      if (support === 'partial') score.partial += 1;
      return score;
    },
    { yes: 0, partial: 0, total: features.length },
  );
}

const visibleFeatures = grouped.flatMap(({ features }) => features);

// Pre-compute per-category breakdown per orchestrator.
const categoryScores = ORCHESTRATORS.map((o) =>
  Object.fromEntries(
    grouped.map(({ category, features }) => [category, scoreFeatures(features, o.features)]),
  ) as Record<FeatureCategory, SupportScore>,
);
const globalScores = ORCHESTRATORS.map((o) => scoreFeatures(visibleFeatures, o.features));

// Counts the tools visible by default (at least one approved version). Tools
// whose only versions are waiting-for-review are unlocked client-side via
// `?preview=` and shouldn't inflate the SSR-rendered headline count.
const toolCount = Object.values(ORCHESTRATORS_BY_TOOL).filter((versions) =>
  versions.some(isApproved),
).length;
const featureCount = visibleFeatures.length;
---

<section class="comparator" aria-labelledby="comparator-title">
  <header class="comparator__intro">
    <div>
      <p class="comparator__eyebrow">Main event</p>
      <h2 id="comparator-title" class="comparator__title">
        <span data-tool-count>{toolCount}</span>&nbsp;contenders&nbsp;·&nbsp;{featureCount}&nbsp;rounds
      </h2>
      <p class="comparator__lede">
        Every feature, every tool, every verdict. Headers stay pinned — scroll vertically through the card, horizontally through the lineup.
      </p>
    </div>
    <ul class="legend" aria-label="Verdict legend">
      <li><span class="legend__dot legend__dot--yes" aria-hidden="true">●</span>Supported</li>
      <li><span class="legend__dot legend__dot--partial" aria-hidden="true">◐</span>Partial</li>
      <li><span class="legend__dot legend__dot--no" aria-hidden="true">○</span>No</li>
      <li><span class="legend__dot legend__dot--unknown" aria-hidden="true">?</span>Unknown</li>
    </ul>
  </header>

  <div class="table-shell" role="region" aria-label="Comparison table" tabindex="0">
      <table class="grid">
        <colgroup>
          <col class="col--feature" />
          {ORCHESTRATORS.map((o) => (
            <col
              class="col--tool"
              data-preview-key={previewKey(o)}
              data-tool-id={o.toolId}
              data-display-mode={displayMode(o)}
            />
          ))}
        </colgroup>

        <thead>
          <tr>
            <th scope="col" class="cell--corner">
              <span class="cell--corner__kicker">Feature</span>
              <span class="cell--corner__hint">vs.</span>
            </th>
            {ORCHESTRATORS.map((o, idx) => {
              const pricingDisplay = getPricingDisplay(idx);
              const codebaseDisplay = o.codebase ? codebaseFlag[o.codebase] : null;
              const vd = o.versionDetails;
              const versionTooltip = vd
                ? [vd.buildHash && `(${vd.buildHash})`, vd.buildDate].filter(Boolean).join(' ')
                : undefined;
              const toolVersions = ORCHESTRATORS_BY_TOOL[o.toolId];
              const defaultVersion = defaultVersionFor(o.toolId);
              // Dropdown lists every version of the tool; pending options carry
              // `data-pending` so the client script can hide the ones that the
              // viewer has not explicitly unlocked via `?preview=`. Approved
              // versions are always shown — they are public knowledge.
              const dropdownVersions = toolVersions;
              return (
              <th
                scope="col"
                class="cell--tool"
                data-preview-key={previewKey(o)}
                data-tool-id={o.toolId}
                data-display-mode={displayMode(o)}
              >
                <div class="tool">
                  {/* 1/ Title */}
                  <a class="tool__name" href={o.homepage} target="_blank" rel="noreferrer">{o.toolName}</a>

                  {/* 2/ Global stats */}
                  <div class="tool__row tool__row--score">
                    {(() => {
                      const score = globalScores[idx];
                      return (
                        <div
                          class="score score--global"
                          aria-label={`${score.yes} supported plus ${score.partial} partial out of ${score.total} visible features for ${o.toolName}`}
                        >
                          <span class="score__item score__item--yes">
                            <span class="score__glyph" aria-hidden="true">●</span>
                            <span class="score__value">{score.yes}</span>
                          </span>
                          <span class="score__operator" aria-hidden="true">+</span>
                          <span class="score__item score__item--partial">
                            <span class="score__glyph" aria-hidden="true">◐</span>
                            <span class="score__value">{score.partial}</span>
                          </span>
                          <span class="score__den">/ {score.total}</span>
                        </div>
                      );
                    })()}
                  </div>

                  {/* 3/ Pricing + codebase duo */}
                  <div class="tool__row tool__row--pricing">
                    {pricingDisplay && (
                      o.pricingSource ? (
                        <Evidence
                          variant="inline"
                          refLabel={`${o.toolId.replace(/-/g, ' ')} · pricing`}
                          sourceUrl={o.pricingSource.sourceUrl}
                          sourceExtract={o.pricingSource.sourceExtract}
                          ariaLabel={`Show source for pricing on ${o.toolName}`}
                        >
                          <span class={`tool__pill tool__pill--${pricingDisplay}`}>{pricingDisplay}</span>
                        </Evidence>
                      ) : (
                        <span class={`tool__pill tool__pill--${pricingDisplay}`}>{pricingDisplay}</span>
                      )
                    )}
                    {codebaseDisplay && (
                      o.codebaseSource ? (
                        <Evidence
                          variant="inline"
                          refLabel={`${o.toolId.replace(/-/g, ' ')} · ${codebaseDisplay.label}`}
                          sourceUrl={o.codebaseSource.sourceUrl}
                          sourceExtract={o.codebaseSource.sourceExtract}
                          ariaLabel={`Show source for ${codebaseDisplay.label} codebase on ${o.toolName}`}
                        >
                          <span class={`tool__flag tool__flag--${codebaseDisplay.modifier}`}>{codebaseDisplay.label}</span>
                        </Evidence>
                      ) : (
                        <span
                          class={`tool__flag tool__flag--${codebaseDisplay.modifier}`}
                          title={codebaseDisplay.title}
                        >{codebaseDisplay.label}</span>
                      )
                    )}
                  </div>

                  {/* 4/ Version + release date — when the tool has multiple
                       versions on file, the version label itself becomes a
                       dropdown so readers can pivot without a separate row. */}
                  <div class="tool__row tool__row--version">
                    {dropdownVersions.length > 1 ? (
                      <>
                        <select
                          class="tool__version tool__version--switcher"
                          data-tool-id={o.toolId}
                          data-default-version={defaultVersion}
                          aria-label={`Switch displayed version of ${o.toolName}`}
                          title={versionTooltip}
                        >
                          {dropdownVersions.map((v) => (
                            <option
                              value={v.version}
                              selected={v.version === o.version}
                              data-pending={!isApproved(v) ? 'true' : null}
                            >
                              v{v.version}
                              {v.version === defaultVersion ? ' · latest' : ''}
                              {!isApproved(v) ? ' · preview' : ''}
                            </option>
                          ))}
                        </select>
                        {/* Static fallback shown by the client script when the
                            dropdown would only have one visible option (every
                            other version is a pending one the viewer hasn't
                            unlocked) — keeps a useless 1-option select from
                            hinting at hidden previews. */}
                        <span
                          class={`tool__version tool__version--fallback${versionTooltip ? ' tool__version--has-tooltip' : ''}`}
                          title={versionTooltip}
                          hidden
                        >
                          v{o.version}{isDefaultVisible(o) ? ' · latest' : ''}{!isApproved(o) ? ' · preview' : ''}
                        </span>
                      </>
                    ) : versionTooltip ? (
                      <span class="tool__version tool__version--has-tooltip" title={versionTooltip}>
                        v{o.version}{isDefaultVisible(o) ? ' · latest' : ''}{!isApproved(o) ? ' · preview' : ''}
                      </span>
                    ) : (
                      <span class="tool__version">
                        v{o.version}{isDefaultVisible(o) ? ' · latest' : ''}{!isApproved(o) ? ' · preview' : ''}
                      </span>
                    )}
                    {o.releaseDate ? (
                      <span class="tool__release" title={`Released ${o.releaseDate}`}>
                        <span class="tool__release-label">Released</span>
                        <time datetime={o.releaseDate}>{o.releaseDate}</time>
                      </span>
                    ) : (
                      <span class="tool__release tool__release--placeholder" aria-hidden="true">&nbsp;</span>
                    )}
                  </div>

                  {/* 5/ Supported platforms */}
                  <div class="tool__row tool__row--platforms">
                    {o.platforms && o.platforms.length > 0 ? (
                      <ul class="tool__platforms" aria-label="Supported platforms">
                        {o.platforms.map((p) => {
                          const src = o.platformSources?.[p];
                          return (
                            <li class="tool__platform-item">
                              {src ? (
                                <Evidence
                                  variant="inline"
                                  refLabel={`${o.toolId.replace(/-/g, ' ')} · ${p}`}
                                  sourceUrl={src.sourceUrl}
                                  sourceExtract={src.sourceExtract}
                                  ariaLabel={`Show source for ${platformTooltip[p]} on ${o.toolName}`}
                                >
                                  <span class={`tool__platform tool__platform--${p}`}>{platformLabel[p]}</span>
                                </Evidence>
                              ) : (
                                <span class={`tool__platform tool__platform--${p}`} title={platformTooltip[p]}>
                                  {platformLabel[p]}
                                </span>
                              )}
                            </li>
                          );
                        })}
                      </ul>
                    ) : (
                      <span class="tool__platforms-placeholder" aria-hidden="true">&nbsp;</span>
                    )}
                  </div>

                </div>
              </th>
              );
            })}
          </tr>
        </thead>

        <tbody>
          {ORCHESTRATORS.some((o) => o.modelRestriction || o.misc || !isApproved(o)) && (
            <tr class="row--notices">
              <th scope="row" class="cell--notices-label">
                <span class="cell--notices-label__text">Worth noting</span>
              </th>
              {ORCHESTRATORS.map((o) => {
                const pending = !isApproved(o);
                const hasContent = !!(o.modelRestriction || o.misc || pending);
                return (
                  <td
                    class="cell--notices"
                    data-preview-key={previewKey(o)}
                    data-tool-id={o.toolId}
                    data-display-mode={displayMode(o)}
                  >
                    {hasContent && (
                      <div class="notices">
                        {o.modelRestriction && (
                          <p class="tool__notice tool__notice--models" role="note">
                            <span class="tool__notice-icon" aria-hidden="true">⚠</span>
                            <span class="tool__notice-text">
                              {o.modelRestriction.sourceUrl
                                ? <a href={o.modelRestriction.sourceUrl} target="_blank" rel="noreferrer">{o.modelRestriction.message}</a>
                                : o.modelRestriction.message}
                            </span>
                          </p>
                        )}
                        {o.misc && (
                          <p class="tool__notice" role="note">
                            <span class="tool__notice-icon" aria-hidden="true">⚠</span>
                            <span class="tool__notice-text">
                              {o.misc.sourceUrl
                                ? <a href={o.misc.sourceUrl} target="_blank" rel="noreferrer">{o.misc.message}</a>
                                : o.misc.message}
                            </span>
                          </p>
                        )}
                        {pending && (
                          <p class="tool__preview-banner" role="note">
                            <span class="tool__preview-banner-tag">Preview</span>
                            <span class="tool__preview-banner-text">
                              v{o.version} is waiting for review — not yet part of the public dataset.
                            </span>
                          </p>
                        )}
                      </div>
                    )}
                  </td>
                );
              })}
            </tr>
          )}
          {ORCHESTRATORS.some((o) => (o.modelIntegrations?.length ?? 0) > 0) && (
            <tr class="row--wiring">
              <th scope="row" class="cell--wiring-label">
                <span class="cell--wiring-label__text">Model wiring</span>
                <span class="cell--wiring-label__hint">how vendor models are plugged in</span>
              </th>
              {ORCHESTRATORS.map((o) => {
                const integrations = o.modelIntegrations ?? [];
                return (
                  <td
                    class="cell--wiring"
                    data-preview-key={previewKey(o)}
                    data-tool-id={o.toolId}
                    data-display-mode={displayMode(o)}
                  >
                    {integrations.length > 0 ? (
                      <ul class="wiring" role="list">
                        {integrations.map((mi) => {
                          const hasEvidence = !!(mi.sourceUrl && mi.sourceExtract);
                          const pill = (
                            <span class="wiring__row">
                              <span class="wiring__vendor" title={mi.notes}>{mi.vendor}</span>
                              <span
                                class={`wiring__kind wiring__kind--${mi.kind}`}
                                title={integrationKindTooltip[mi.kind]}
                              >
                                {integrationKindLabel[mi.kind]}
                              </span>
                            </span>
                          );
                          return (
                            <li class="wiring__item">
                              {hasEvidence ? (
                                <Evidence
                                  variant="inline"
                                  refLabel={`${o.toolId.replace(/-/g, ' ')} · ${mi.vendor.toLowerCase()} wiring`}
                                  sourceUrl={mi.sourceUrl}
                                  sourceExtract={mi.sourceExtract}
                                  ariaLabel={`Show source for ${mi.vendor} model wiring on ${o.toolName}`}
                                >
                                  {pill}
                                </Evidence>
                              ) : pill}
                              {mi.notes && <p class="wiring__notes">{mi.notes}</p>}
                            </li>
                          );
                        })}
                      </ul>
                    ) : (
                      <span class="wiring__empty" aria-hidden="true">—</span>
                    )}
                  </td>
                );
              })}
            </tr>
          )}
          {grouped.map((group) => (
            <>
              <tr class="row--category">
                <th scope="rowgroup" class="cell--category">
                  <span class="cell--category__label">{categoryLabel[group.category]}</span>
                  <span class="cell--category__count">{group.features.length} feature{group.features.length > 1 ? 's' : ''}</span>
                </th>
                {ORCHESTRATORS.map((o, i) => {
                  const s = categoryScores[i][group.category];
                  return (
                    <td
                      class="cell--category-score"
                      data-preview-key={previewKey(o)}
                      data-tool-id={o.toolId}
                      data-display-mode={displayMode(o)}
                      aria-label={`${s.yes} supported plus ${s.partial} partial out of ${s.total} ${categoryLabel[group.category]} features`}
                    >
                      <div class="score score--category">
                        <span class="score__item score__item--yes">
                          <span class="score__glyph" aria-hidden="true">●</span>
                          <span class="score__value">{s.yes}</span>
                        </span>
                        <span class="score__operator" aria-hidden="true">+</span>
                        <span class="score__item score__item--partial">
                          <span class="score__glyph" aria-hidden="true">◐</span>
                          <span class="score__value">{s.partial}</span>
                        </span>
                        <span class="score__den">/ {s.total}</span>
                      </div>
                    </td>
                  );
                })}
              </tr>
              {group.features.map((feature: Feature) => (
                <tr class="row--feature">
                  <th scope="row" class="cell--feature">
                    <div class="feature">
                      <p class="feature__label">{feature.label}</p>
                      <p class="feature__body">{feature.longDescription ?? feature.shortDescription}</p>
                    </div>
                  </th>
                  {ORCHESTRATORS.map((orch, i) => {
                    const s = findSupport(i, feature.id);
                    const level: SupportLevel = s?.support ?? 'unknown';
                    const hasEvidence = !!(s?.sourceUrl && s?.sourceExtract) || (s?.screenshots?.length ?? 0) > 0;
                    return (
                      <td
                        class={`cell cell--${level}`}
                        data-support={level}
                        data-preview-key={previewKey(orch)}
                        data-tool-id={orch.toolId}
                        data-display-mode={displayMode(orch)}
                      >
                        <span class="cell__glyph" aria-label={supportLabel[level]} role="img">{supportGlyph[level]}</span>
                        {s?.note && <p class="cell__note">{s.note}</p>}
                        {hasEvidence && (
                          <Evidence
                            variant="cell"
                            refLabel={`${orch.toolId.replace(/-/g, ' ')} · ${feature.id.replace(/-/g, ' ')}`}
                            sourceUrl={s?.sourceUrl}
                            sourceExtract={s?.sourceExtract}
                            screenshots={s?.screenshots}
                            ariaLabel={`Show source for ${feature.label} on ${orch.toolName}`}
                          />
                        )}
                      </td>
                    );
                  })}
                </tr>
              ))}
            </>
          ))}
        </tbody>
      </table>
  </div>

  <section class="sources" aria-labelledby="sources-title">
    <header class="sources__head">
      <p class="sources__eyebrow">Reference desk</p>
      <h3 id="sources-title" class="sources__title">Tracking sources</h3>
      <p class="sources__lede">
        Where each vendor publishes news, changelogs, and docs. Used as the starting point when refreshing this dataset for a new release — no need to re-hunt every cycle.
      </p>
    </header>
    <ul class="sources__grid" role="list">
      {ORCHESTRATORS.map((o) => (
        <li
          class="sources__card"
          data-preview-key={previewKey(o)}
          data-tool-id={o.toolId}
          data-display-mode={displayMode(o)}
        >
          <h4 class="sources__tool">
            <a href={o.homepage} target="_blank" rel="noreferrer">{o.toolName}</a>
          </h4>
          {o.trackingSources && o.trackingSources.length > 0 ? (
            <ul class="sources__list" role="list">
              {o.trackingSources.map((src) => (
                <li class="sources__item">
                  <span class={`sources__kind sources__kind--${src.kind}`}>{trackingKindLabel[src.kind]}</span>
                  <a class="sources__link" href={src.url} target="_blank" rel="noreferrer">{src.label}</a>
                  {src.notes && <span class="sources__notes">{src.notes}</span>}
                </li>
              ))}
            </ul>
          ) : (
            <p class="sources__empty">No tracking sources registered yet.</p>
          )}
        </li>
      ))}
    </ul>
  </section>
</section>

<style>
  /* ============ Intro ============ */
  .comparator { display: flex; flex-direction: column; gap: var(--s-5); }
  .comparator__intro {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--s-5);
    flex-wrap: wrap;
  }
  .comparator__eyebrow {
    margin: 0 0 var(--s-2);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 700;
  }
  .comparator__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 900;
    text-transform: uppercase;
    font-size: clamp(1.4rem, 2.6vw, 2rem);
    letter-spacing: 0.005em;
    color: var(--fg);
    line-height: 1;
  }
  .comparator__lede {
    margin: var(--s-3) 0 0;
    color: var(--fg-soft);
    max-width: 60ch;
  }

  .legend {
    list-style: none;
    margin: 0;
    padding: var(--s-3) var(--s-4);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-md);
    background: var(--bg-elev);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4);
    font-size: 0.8rem;
    color: var(--fg-soft);
  }
  .legend li { display: inline-flex; align-items: center; gap: var(--s-2); }
  .legend__dot {
    display: inline-grid;
    place-items: center;
    width: 1.2em;
    font-size: 1.05em;
    line-height: 1;
  }
  .legend__dot--yes      { color: var(--cell-yes-ink); }
  .legend__dot--partial  { color: var(--cell-partial-ink); }
  .legend__dot--no       { color: var(--cell-no-ink); }
  .legend__dot--unknown  { color: var(--cell-unknown-ink); }

  /* ============ Table shell ============ */
  .table-shell {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-elev);
    box-shadow: var(--shadow-card);
    /* Single scrollbar = the page's. No internal scroll container, so sticky
       cells anchor to the viewport itself. */
    overflow: visible;
  }
  .table-shell:focus-visible { outline: 2px solid var(--accent); outline-offset: -2px; }

  .grid {
    table-layout: fixed; /* fixed widths => toggling feature details doesn't reflow columns */
    border-collapse: separate;
    border-spacing: 0;
    width: max-content;
    min-width: 100%;
    font-size: 0.9rem;
  }

  /* Column widths — fixed-layout means these are authoritative */
  .col--feature { width: 300px; }
  .col--tool    { width: 230px; }

  /* ============ Cells ============ */
  th, td {
    text-align: left;
    vertical-align: top;
    padding: var(--s-4);
    border-bottom: 1px solid var(--border-soft);
    border-right: 1px solid var(--border-soft);
  }
  td:last-child, th:last-child { border-right: none; }
  tbody tr:last-child td,
  tbody tr:last-child th { border-bottom: none; }

  /* ============ Corner (top-left) ============ */
  .cell--corner {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 5;
    background: var(--bg-row);
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    font-family: var(--font-display);
    text-transform: uppercase;
    padding: var(--s-4) var(--s-4) var(--s-3);
  }
  .cell--corner__kicker {
    display: block;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--fg);
  }
  .cell--corner__hint {
    display: block;
    margin-top: var(--s-2);
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: var(--accent);
    font-weight: 700;
  }

  /* ============ Tool header column ============ */
  .cell--tool {
    position: sticky;
    top: 0;
    z-index: 3;
    background: var(--bg-row);
    border-bottom: 1px solid var(--border);
    padding: var(--s-4) var(--s-3);
  }
  /* When a header cell has an open proof popover, lift it above sibling sticky
     headers so the card isn't clipped by the next column's stacking context. */
  .cell--tool:has(.evidence[open]) { z-index: 6; }
  .cell--corner:has(.evidence[open]) { z-index: 7; }
  .tool { display: flex; flex-direction: column; gap: var(--s-2); position: relative; }
  .tool__name {
    display: block;
    min-height: 2.9rem;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.45rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--fg);
    letter-spacing: 0.005em;
    margin-top: 2px;
    word-break: break-word;
  }
  .tool__name:hover, .tool__name:focus-visible { color: var(--accent); text-decoration: none; }

  /* Vertically aligned header rows. Every column reserves the same vertical
     space per row — empty placeholders are inserted when a tool is missing
     data — so titles, scores, pricing duos, versions, platforms and warnings
     all line up horizontally across the lineup. */
  .tool__row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--s-2);
  }
  .tool__row--score    { min-height: 2rem; }
  .tool__row--pricing  { min-height: 1.5rem; }
  .tool__row--version  {
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-height: 2.1rem;
  }
  .tool__row--platforms { min-height: 1.5rem; align-items: flex-start; }
  .tool__version {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .tool__version--has-tooltip {
    cursor: help;
    text-decoration: underline dotted;
    text-underline-offset: 3px;
    text-decoration-color: var(--fg-faint);
  }
  /* When a tool has multiple known versions on file, the version label is
     rendered as a `<select>` so readers can pivot in place without an extra
     row in the header. The dropdown adopts the same display typography as
     the static version label and inherits the column width, with a discreet
     caret hinting at its interactivity. */
  .tool__version--switcher {
    appearance: none;
    -webkit-appearance: none;
    padding: 2px 18px 2px 4px;
    margin-left: -4px;
    max-width: 100%;
    border: 1px solid transparent;
    border-radius: var(--radius-sm, 4px);
    background-color: transparent;
    background-image: linear-gradient(45deg, transparent 50%, currentColor 50%),
      linear-gradient(135deg, currentColor 50%, transparent 50%);
    background-position: calc(100% - 8px) 55%, calc(100% - 4px) 55%;
    background-size: 4px 4px, 4px 4px;
    background-repeat: no-repeat;
    color: var(--fg-muted);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    line-height: 1;
  }
  .tool__version--switcher:hover,
  .tool__version--switcher:focus-visible {
    border-color: var(--border);
    color: var(--fg);
    background-color: oklch(0.22 0.012 28);
    outline: none;
  }
  .tool__version--switcher option {
    /* Native option styling: opt back into a readable, non-uppercase rendering
       so the version list is easy to scan in the open popup. */
    font-size: 0.85rem;
    letter-spacing: 0.02em;
    text-transform: none;
    color: var(--fg);
    background: var(--bg-elev);
  }
  .tool__pill {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--fg-soft);
    background: oklch(0.22 0.012 28);
  }
  .tool__pill--oss      { color: oklch(0.82 0.13 145); border-color: oklch(0.4 0.06 145); }
  .tool__pill--free     { color: oklch(0.82 0.11 220); border-color: oklch(0.4 0.05 220); }
  .tool__pill--freemium { color: oklch(0.85 0.12 85);  border-color: oklch(0.4 0.06 85); }
  .tool__pill--paid     { color: oklch(0.85 0.12 28);  border-color: oklch(0.4 0.07 28); }

  /* Free-tier flag — visually distinct from pricing pill (filled rectangle vs. rounded outline)
     to communicate "perk available" rather than "pricing model". */
  .tool__flag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 6px;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    border-radius: 2px;
    cursor: help;
    /* Coupon / ticket-stub treatment, picks up the canvas (cream) accent */
    color: oklch(0.30 0.06 80);
    background: var(--canvas);
    box-shadow:
      0 1px 0 oklch(0 0 0 / 0.35),
      0 0 0 1px oklch(0.55 0.05 60 / 0.35);
  }
  /* Codebase chips paired with the pricing pill. Closed-source reads red,
     OSS reads green — keeping the source-availability signal scannable. */
  .tool__flag--closed-source {
    color: oklch(0.82 0.14 28);
    background: transparent;
    box-shadow: inset 0 0 0 1px oklch(0.45 0.12 28);
  }
  .tool__flag--oss {
    color: oklch(0.82 0.14 145);
    background: transparent;
    box-shadow: inset 0 0 0 1px oklch(0.45 0.11 145);
  }

  .tool__release {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-display);
    font-size: 0.68rem;
    color: var(--fg-muted);
    letter-spacing: 0.06em;
  }
  .tool__release--placeholder { visibility: hidden; }
  .tool__release-label {
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--fg-faint);
    font-size: 0.6rem;
  }
  .tool__release time { font-variant-numeric: tabular-nums; }

  .score {
    display: inline-flex;
    align-items: baseline;
    gap: 5px;
    font-family: var(--font-display);
    white-space: nowrap;
  }
  .score--global {
    padding: 5px var(--s-2);
    border: 1px solid var(--border-soft);
    border-radius: var(--radius-sm);
    background: oklch(0.19 0.014 25);
  }
  .score__item {
    display: inline-flex;
    align-items: baseline;
    gap: 3px;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .score__glyph {
    font-family: var(--font-body);
    font-size: 0.72rem;
    transform: translateY(-1px);
  }
  .score__value {
    font-size: 1.05rem;
    font-weight: 900;
  }
  .score__operator {
    color: var(--fg-faint);
    font-size: 0.82rem;
    font-weight: 900;
  }
  .score__den {
    font-size: 0.72rem;
    color: var(--fg-muted);
    font-weight: 700;
    letter-spacing: 0.06em;
  }
  .score__item--yes { color: var(--cell-yes-ink); }
  .score__item--partial { color: var(--cell-partial-ink); }
  .score--global .score__value { font-size: 1rem; }
  .score--global .score__glyph { font-size: 0.68rem; }

  .tool__platforms {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .tool__platform {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: oklch(0.22 0.012 28);
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-soft);
    line-height: 1;
    cursor: help;
  }
  .tool__platform--macos   { color: oklch(0.92 0.02 250); border-color: oklch(0.4 0.03 250); }
  .tool__platform--windows { color: oklch(0.85 0.1 220);  border-color: oklch(0.4 0.05 220); }
  .tool__platform--linux   { color: oklch(0.85 0.1 85);   border-color: oklch(0.4 0.06 85); }
  .tool__platform--web     { color: oklch(0.85 0.1 145);  border-color: oklch(0.4 0.05 145); }

  .tool__notice {
    margin: 0;
    padding: var(--s-2) var(--s-3);
    display: flex;
    align-items: flex-start;
    gap: var(--s-2);
    border: 1px solid oklch(0.4 0.09 60);
    border-radius: var(--radius-sm, 6px);
    background: oklch(0.28 0.06 60 / 0.35);
    font-size: 0.72rem;
    line-height: 1.4;
    color: oklch(0.92 0.08 80);
  }
  .tool__notice-icon {
    flex-shrink: 0;
    font-size: 0.85rem;
    line-height: 1.2;
    color: oklch(0.85 0.14 70);
  }
  .tool__notice-text { min-width: 0; }
  .tool__notice a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: oklch(0.6 0.1 70);
  }
  .tool__notice a:hover,
  .tool__notice a:focus-visible {
    text-decoration-color: currentColor;
  }

  /* ============ Notices row (non-sticky, sits between header and first category) ============ */
  .row--notices .cell--notices-label {
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--bg);
    border-right: 1px solid var(--border);
    vertical-align: top;
    padding: var(--s-3) var(--s-4);
  }
  /* "Worth noting" reads as a ringside placard — warm amber on the dark band,
     same display face as the category labels but pulled brighter and tinted
     toward the accent corner-red so it announces itself rather than mumbling. */
  .cell--notices-label__text {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    font-weight: 800;
    color: oklch(0.82 0.1 45);
  }
  .row--notices .cell--notices {
    background: var(--bg);
    vertical-align: top;
    padding: var(--s-3);
  }
  .notices {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }

  /* ============ Model wiring row ============
     A second meta band, sitting underneath "Worth noting". Where Worth noting
     is a warm amber placard, Model wiring uses a cool steel-blue palette so
     readers can tell the two bands apart even without reading the labels.
     Each entry pairs a vendor name with a compact, color-coded chip naming
     the integration kind (SDK / CLI / ACP / MCP …). Color is keyed per kind
     so the same wiring style is easy to spot across columns. */
  .row--wiring .cell--wiring-label {
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--bg);
    border-right: 1px solid var(--border);
    vertical-align: top;
    padding: var(--s-3) var(--s-4);
  }
  .cell--wiring-label__text {
    display: block;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    font-weight: 800;
    color: oklch(0.84 0.07 220);
  }
  .cell--wiring-label__hint {
    display: block;
    margin-top: 4px;
    font-size: 0.66rem;
    line-height: 1.35;
    letter-spacing: 0.04em;
    color: var(--fg-faint);
    text-transform: none;
    font-weight: 500;
  }
  .row--wiring .cell--wiring {
    background: var(--bg);
    vertical-align: top;
    padding: var(--s-3);
  }
  /* Subtle steel-blue tint differentiates this band from the surrounding
     rows without overpowering the table — the dominant colour stays the
     base canvas, the tint is just enough to read as a meta band. */
  .row--wiring .cell--wiring-label,
  .row--wiring .cell--wiring {
    background: color-mix(in oklch, oklch(0.32 0.04 230) 14%, var(--bg));
    border-bottom: 1px solid var(--border);
  }
  .wiring {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .wiring__item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .wiring__row {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    min-width: 0;
  }
  .wiring__vendor {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-soft);
    line-height: 1.1;
    white-space: nowrap;
  }
  /* Connector glyph between vendor and kind chip — keeps the "wiring"
     metaphor literal without taking visual weight. */
  .wiring__row::before {
    content: '→';
    color: var(--fg-faint);
    font-size: 0.72rem;
    line-height: 1;
    order: 0;
  }
  .wiring__vendor { order: -1; }
  .wiring__kind { order: 1; }
  .wiring__kind {
    display: inline-flex;
    align-items: center;
    padding: 3px 7px;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: oklch(0.22 0.012 28);
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--fg-soft);
    line-height: 1;
    cursor: help;
    white-space: nowrap;
  }
  /* Per-kind palette — each integration mechanism gets a distinct hue so
     readers can scan across columns and spot patterns at a glance. Hues are
     spread across the wheel and kept at the same lightness/chroma envelope
     so no single chip outshouts the others. */
  .wiring__kind--cli-subprocess      { color: oklch(0.85 0.12 85);  border-color: oklch(0.42 0.07 85); }
  .wiring__kind--provider-sdk        { color: oklch(0.85 0.12 250); border-color: oklch(0.42 0.07 250); }
  .wiring__kind--app-server-jsonrpc  { color: oklch(0.85 0.11 195); border-color: oklch(0.42 0.06 195); }
  .wiring__kind--acp                 { color: oklch(0.85 0.13 145); border-color: oklch(0.42 0.07 145); }
  .wiring__kind--openai-compatible-api { color: oklch(0.85 0.12 165); border-color: oklch(0.42 0.06 165); }
  .wiring__kind--mcp                 { color: oklch(0.85 0.13 305); border-color: oklch(0.42 0.07 305); }
  .wiring__kind--other               { color: var(--fg-muted); border-color: var(--border); }
  .wiring__notes {
    margin: 2px 0 0;
    padding-left: calc(0.72rem + 6px); /* align with text after the connector arrow */
    font-size: 0.72rem;
    line-height: 1.4;
    color: var(--fg-muted);
  }
  .wiring__empty {
    color: var(--fg-faint);
    font-family: var(--font-display);
  }

  /* ============ Category rows ============ */
  .row--category .cell--category {
    position: sticky;
    left: 0;
    background: var(--bg-elev);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    border-right: 1px solid var(--border);
    padding: var(--s-3) var(--s-4);
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.72rem;
    color: var(--fg-muted);
    z-index: 2;
    /* z-index lower than thead (3/5) but above body cells (1) */
  }
  .row--category .cell--category-score {
    background: var(--bg-elev);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: var(--s-3) var(--s-4);
    font-family: var(--font-display);
    text-align: left;
    vertical-align: baseline;
    white-space: nowrap;
  }
  .cell--category-score .score__value { font-size: 1.15rem; }
  .cell--category__label {
    color: var(--canvas);
    font-weight: 900;
    letter-spacing: 0.24em;
    font-size: 0.78rem;
    margin-right: var(--s-3);
  }
  .cell--category__count {
    color: var(--fg-faint);
    font-weight: 700;
    letter-spacing: 0.18em;
  }

  /* ============ Feature column (sticky-left) ============ */
  .cell--feature {
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--bg);
    border-right: 1px solid var(--border);
    font-weight: 500;
    color: var(--fg);
    padding: 0;
  }
  .row--feature:nth-child(even) .cell--feature { background: var(--bg-row-alt); }

  .feature {
    width: 100%;
    padding: var(--s-4);
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
  }
  .feature__label {
    margin: 0;
    line-height: 1.35;
    font-weight: 500;
  }
  .feature__body {
    margin: 0;
    color: var(--fg-muted);
    font-size: 0.825rem;
    line-height: 1.5;
  }

  /* ============ Support cells ============ */
  .cell {
    background: var(--bg);
    transition: background .15s ease;
    position: relative;
  }
  .row--feature:nth-child(even) .cell { background: var(--bg-row-alt); }

  /* State backgrounds (subtle, no stripes) */
  .cell--yes      { background: color-mix(in oklch, var(--cell-yes) 60%, var(--bg)); }
  .cell--no       { background: color-mix(in oklch, var(--cell-no) 55%, var(--bg)); }
  .cell--partial  { background: color-mix(in oklch, var(--cell-partial) 55%, var(--bg)); }
  .cell--unknown  { background: var(--bg); }

  .row--feature:nth-child(even) .cell--yes     { background: color-mix(in oklch, var(--cell-yes) 65%, var(--bg-row-alt)); }
  .row--feature:nth-child(even) .cell--no      { background: color-mix(in oklch, var(--cell-no) 60%, var(--bg-row-alt)); }
  .row--feature:nth-child(even) .cell--partial { background: color-mix(in oklch, var(--cell-partial) 60%, var(--bg-row-alt)); }

  /* Highlight the row on hover for cross-reference */
  .row--feature:hover .cell { background-color: oklch(0.25 0.018 28 / 0.45); }
  .row--feature:hover .cell--feature { background-color: color-mix(in oklch, oklch(0.25 0.018 28) 45%, var(--bg)); }
  .row--feature:nth-child(even):hover .cell--feature { background-color: color-mix(in oklch, oklch(0.25 0.018 28) 45%, var(--bg-row-alt)); }
  .row--feature:hover .cell--yes     { background-color: color-mix(in oklch, var(--cell-yes) 75%, oklch(0.25 0.018 28)); }
  .row--feature:hover .cell--no      { background-color: color-mix(in oklch, var(--cell-no) 75%, oklch(0.25 0.018 28)); }
  .row--feature:hover .cell--partial { background-color: color-mix(in oklch, var(--cell-partial) 75%, oklch(0.25 0.018 28)); }

  .cell__glyph {
    display: inline-block;
    font-size: 1.4rem;
    line-height: 1;
    font-family: var(--font-body);
  }
  .cell--yes     .cell__glyph { color: var(--cell-yes-ink); }
  .cell--no      .cell__glyph { color: var(--cell-no-ink); }
  .cell--partial .cell__glyph { color: var(--cell-partial-ink); }
  .cell--unknown .cell__glyph {
    color: var(--cell-unknown-ink);
    font-size: 1.05rem;
    font-weight: 700;
  }

  .cell__note {
    margin: var(--s-2) 0 0;
    font-size: 0.78rem;
    line-height: 1.45;
    color: var(--fg-soft);
  }

  /* Cell-level evidence margin (parent .cell is position:relative — see below) */
  .evidence--cell { margin-top: var(--s-3); }

  /* ============ Tracking sources section ============ */
  .sources {
    padding: var(--s-5);
    border: 1px solid var(--border);
