---
interface Screenshot {
  src: string;
  alt: string;
  caption?: string;
}

interface Props {
  /** Short, all-lowercase reference shown in the card kicker — e.g. "vibe kanban · oss" */
  refLabel: string;
  sourceUrl?: string;
  sourceExtract?: string;
  /** Optional gallery of screenshots. When present, the card widens and a near-fullscreen
   *  preview dominates the popover; multiple entries enable a carousel. */
  screenshots?: Screenshot[];
  /** 'cell' renders a built-in "▸ Proof" trigger. 'inline' uses the slot as the trigger
   *  (caller is responsible for the visible element — typically a pre-styled pill/flag span). */
  variant?: 'cell' | 'inline';
  /** ARIA label for screen readers describing what this proof attests to. */
  ariaLabel?: string;
}

const {
  refLabel,
  sourceUrl,
  sourceExtract,
  screenshots = [],
  variant = 'cell',
  ariaLabel,
} = Astro.props;

const shots = screenshots.filter((s) => s && s.src);
const hasShots = shots.length > 0;
const hasQuote = !!(sourceUrl && sourceExtract);

function prettyUrl(u: string): string {
  try {
    const url = new URL(u);
    const host = url.hostname.replace(/^www\./, '');
    const path = url.pathname.replace(/\/$/, '');
    return path && path.length > 1 ? `${host}${path}` : host;
  } catch {
    return u;
  }
}
---

<details class={`evidence evidence--${variant}`} name="proof">
  <summary class="evidence__trigger" aria-label={ariaLabel}>
    {variant === 'cell' ? (
      <>
        <span class="evidence__chevron" aria-hidden="true"></span>
        <span class="evidence__trigger-label">Proof</span>
        {hasShots && (
          <span
            class="evidence__shot-badge"
            aria-label={`${shots.length} screenshot${shots.length > 1 ? 's' : ''} available`}
            title={`${shots.length} screenshot${shots.length > 1 ? 's' : ''}`}
          >
            <svg
              class="evidence__shot-badge-icon"
              viewBox="0 0 24 24"
              width="12"
              height="12"
              aria-hidden="true"
              focusable="false"
            >
              {/* Two overlapping UI windows — back frame + front frame with a
                  title bar dot. Reads as "captured screens" rather than camera. */}
              <rect
                x="3.5" y="6.5" width="12" height="10" rx="1.4"
                fill="none" stroke="currentColor" stroke-width="1.4"
                opacity="0.55"
              />
              <rect
                x="8.5" y="9.5" width="12" height="10" rx="1.4"
                fill="currentColor" fill-opacity="0.14"
                stroke="currentColor" stroke-width="1.4"
              />
              <line
                x1="8.5" y1="12.4" x2="20.5" y2="12.4"
                stroke="currentColor" stroke-width="1.4" opacity="0.85"
              />
              <circle cx="10.6" cy="10.95" r="0.7" fill="currentColor" />
            </svg>
            <span class="evidence__shot-badge-count">{shots.length}</span>
          </span>
        )}
      </>
    ) : (
      <slot />
    )}
  </summary>
  <div class="evidence__backdrop" data-close aria-hidden="true"></div>
  <div
    class={`evidence__card${hasShots ? ' evidence__card--wide' : ''}`}
    role="dialog"
    aria-modal="true"
    aria-label={ariaLabel ?? `Proof — ${refLabel}`}
  >
    <header class="evidence__head">
      <span class="evidence__kicker">On record</span>
      <span class="evidence__ref">{refLabel}</span>
    </header>
    <button
      type="button"
      class="evidence__close"
      data-close
      aria-label="Close proof"
      title="Close"
    >
      <span aria-hidden="true">×</span>
    </button>

    {hasShots && (
      /* Lazy-mounted gallery: the <img> markup is built by the inline script
       * on the first <details> toggle. The shots payload travels as JSON in
       * `data-shots` so we keep 0 bytes of <img> in the initial DOM — that
       * cuts the request fan-out on first paint (was ~260 lazy-img requests
       * across the comparison table) and the content-visibility:hidden
       * warnings caused by walking these subtrees at init. */
      <div
        class={`evidence__gallery${shots.length > 1 ? ' evidence__gallery--carousel' : ''}`}
        data-count={shots.length}
        data-index="0"
        data-shots={JSON.stringify(shots)}
        tabindex={shots.length > 1 ? 0 : undefined}
      ></div>
    )}

    {hasQuote && (
      <blockquote class="evidence__quote">
        <span class="evidence__quote-mark" aria-hidden="true">&ldquo;</span>
        <p>{sourceExtract}</p>
      </blockquote>
    )}
    {sourceUrl && (
      <footer class="evidence__foot">
        <span class="evidence__foot-label">Filed at</span>
        <a class="evidence__foot-link" href={sourceUrl} target="_blank" rel="noreferrer">{prettyUrl(sourceUrl)}</a>
      </footer>
    )}
  </div>
</details>

<style is:global>
  /* ============ Evidence (shared) — paper-clipping proof popover ============ */
  .evidence__trigger {
    list-style: none;
    cursor: pointer;
    user-select: none;
  }
  .evidence__trigger::-webkit-details-marker { display: none; }
  .evidence__trigger::marker { content: ''; display: none; }

  /* Inline variant: <details> itself becomes the anchor, sized to its trigger. */
  .evidence--inline {
    display: inline-block;
    position: relative;
    vertical-align: middle;
    line-height: 1;
  }
  .evidence--inline > .evidence__trigger {
    display: inline-flex;
    align-items: center;
    position: relative;
  }
  .evidence--inline > .evidence__trigger > *::after {
    content: '▾';
    display: inline-block;
    margin-left: 5px;
    font-size: 0.78em;
    line-height: 1;
    opacity: 0.55;
    transition: transform .18s ease, opacity .12s ease;
  }
  .evidence--inline[open] > .evidence__trigger > *::after { transform: rotate(180deg); opacity: 1; }
  .evidence--inline > .evidence__trigger:hover > *::after,
  .evidence--inline > .evidence__trigger:focus-visible > *::after { opacity: 1; }
  .evidence--inline > .evidence__trigger:focus-visible {
    outline: 1px dotted currentColor;
    outline-offset: 2px;
  }

  /* Cell variant: small "▸ PROOF" text affordance below a comparison cell. */
  .evidence--cell { margin-top: var(--s-3); }
  .evidence--cell > .evidence__trigger {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 2px 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.62rem;
    line-height: 1;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    /* Warm parchment tone — same hue family as the screenshot badge so the
     * label + badge read as a single typeset mark, and contrast holds on every
     * support-state cell background. */
    color: oklch(0.78 0.045 80);
    transition: color .12s ease;
  }
  .evidence--cell > .evidence__trigger:hover,
  .evidence--cell > .evidence__trigger:focus-visible { color: var(--accent); outline: none; }
  .evidence--cell > .evidence__trigger:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .evidence--cell[open] > .evidence__trigger { color: var(--accent); }
  .evidence__chevron {
    width: 7px;
    height: 7px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: rotate(-45deg);
    transition: transform .18s ease;
  }
  .evidence--cell[open] .evidence__chevron { transform: rotate(45deg); }
  .evidence__trigger-label { display: inline-block; }

  /* Tiny badge next to the "Proof" label hinting that screenshots are attached.
   *
   * Reads as a small parchment tab clipped onto the cell. Light, warm fill
   * guarantees ≥4.5:1 luminance contrast against ALL four support-state cells
   * (all L≈0.22–0.28), regardless of their hue — green "yes", amber "partial",
   * red "no", or slate "unknown". Re-uses the brand canvas color so the badge
   * looks like a torn-paper sticker on the dossier. */
  .evidence__shot-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-left: 5px;
    padding: 2px 5px 2px 4px;
    border-radius: 2px;
    background: oklch(0.92 0.04 80);
    color: oklch(0.32 0.045 45);
    line-height: 1;
    letter-spacing: 0;
    box-shadow:
      inset 0 0 0 1px oklch(0.55 0.05 55 / 0.45),
      0 1px 0 oklch(0 0 0 / 0.22);
    transition:
      background-color .14s ease,
      color .14s ease,
      box-shadow .14s ease,
      transform .22s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .evidence__shot-badge-icon { display: block; }
  .evidence__shot-badge-count {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    transform: translateY(-0.5px);
  }
  .evidence--cell > .evidence__trigger:hover .evidence__shot-badge,
  .evidence--cell > .evidence__trigger:focus-visible .evidence__shot-badge,
  .evidence--cell[open] .evidence__shot-badge {
    background: oklch(0.96 0.05 85);
    color: oklch(0.26 0.06 40);
    box-shadow:
      inset 0 0 0 1px oklch(0.48 0.07 50 / 0.65),
      0 2px 0 oklch(0 0 0 / 0.28);
  }
  .evidence--cell > .evidence__trigger:hover .evidence__shot-badge {
    transform: translateY(-1px) rotate(-2deg);
  }

  /* ---------- Centered modal: backdrop ---------- */
  .evidence__backdrop { display: none; }

  /* Skip rendering (and browser find-in-page indexing) of proof content while
   * the <details> is closed. Without this, Chrome's "find in page" matches text
   * inside the closed card and force-opens the proof. */
  .evidence:not([open]):not([data-closing]) > .evidence__card {
    content-visibility: hidden;
  }
  .evidence[open] > .evidence__backdrop,
  .evidence[data-closing] > .evidence__backdrop {
    display: block;
    position: fixed;
    inset: 0;
    z-index: 998;
    background:
      radial-gradient(ellipse at center, oklch(0.10 0.02 35 / 0.55), oklch(0.06 0.015 35 / 0.78));
    backdrop-filter: blur(2px) saturate(0.85);
    -webkit-backdrop-filter: blur(2px) saturate(0.85);
    cursor: zoom-out;
  }
  @media (prefers-reduced-motion: no-preference) {
    /* The open-in animation is bound to the [open] selector itself so it runs
     * on the same paint that reveals the element — no JS gating, no flicker. */
    .evidence[open]:not([data-closing]) > .evidence__backdrop {
      animation: evidenceBackdropIn .30s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .evidence[data-closing] > .evidence__backdrop {
      animation: evidenceBackdropOut .22s cubic-bezier(0.5, 0, 0.75, 0) both;
    }
    @keyframes evidenceBackdropIn {
      from {
        opacity: 0;
        backdrop-filter: blur(0) saturate(1);
        -webkit-backdrop-filter: blur(0) saturate(1);
      }
      to {
        opacity: 1;
        backdrop-filter: blur(2px) saturate(0.85);
        -webkit-backdrop-filter: blur(2px) saturate(0.85);
      }
    }
    @keyframes evidenceBackdropOut {
      from { opacity: 1; }
      to   { opacity: 0; }
    }
  }

  /* ---------- Centered modal: card ---------- */
  .evidence__card {
    /* Sized for the centered overlay. Override the previous absolute-popover sizing. */
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 999;
    width: min(640px, 92vw);
    max-height: min(88vh, 900px);
    overflow: auto;
    padding: var(--s-4) var(--s-5);
    color: oklch(0.22 0.025 35);
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.55;
    background:
      radial-gradient(circle at 22% 28%, oklch(0 0 0 / 0.045) 0.5px, transparent 1.2px),
      radial-gradient(circle at 76% 78%, oklch(0 0 0 / 0.035) 0.5px, transparent 1.2px),
      var(--canvas);
    background-size: 6px 6px, 9px 9px, 100% 100%;
    border-radius: 2px;
    box-shadow:
      0 1px 0 oklch(1 0 0 / 0.6) inset,
      0 0 0 1px oklch(0.52 0.05 60 / 0.18),
      0 32px 64px -18px oklch(0 0 0 / 0.85),
      0 8px 18px -6px oklch(0 0 0 / 0.45);
    text-align: left;
    white-space: normal;
  }
  /* Wide variant: when the card hosts screenshots, claim nearly the whole viewport. */
  .evidence__card--wide {
    width: min(1280px, calc(100vw - 64px));
    max-height: calc(100vh - 64px);
    padding: var(--s-4) var(--s-5);
  }

  /* The card stays mounted during the out animation by virtue of [data-closing]
   * keeping the element rendered while [open] is still true on the <details>. */
  .evidence[data-closing] > .evidence__card { display: block; }

  @media (prefers-reduced-motion: no-preference) {
    /* Bound to [open] so the animation starts on the same paint that mounts
     * the card — prevents a flash of fully-rendered card before the animation
     * starts. */
    .evidence[open]:not([data-closing]) > .evidence__card {
      animation: evidenceCardIn .44s cubic-bezier(0.16, 1, 0.3, 1) both;
      transform-origin: 50% 30%;
      will-change: transform, opacity, filter;
    }
    .evidence[data-closing] > .evidence__card {
      animation: evidenceCardOut .26s cubic-bezier(0.5, 0, 0.75, 0) both;
      transform-origin: 50% 30%;
      will-change: transform, opacity, filter;
    }
    /* The clipping drops in with a touch of blur (as if focusing into view),
     * settles with a faint counter-rotation — paper flicked onto the desk. */
    @keyframes evidenceCardIn {
      0% {
        opacity: 0;
        transform: translate(-50%, calc(-50% + 26px)) scale(.94) rotate(-.8deg);
        filter: blur(3px);
      }
      55% { filter: blur(0); }
      100% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1) rotate(0);
        filter: blur(0);
      }
    }
    @keyframes evidenceCardOut {
      from {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1) rotate(0);
        filter: blur(0);
      }
      to {
        opacity: 0;
        transform: translate(-50%, calc(-50% + 14px)) scale(.97) rotate(.5deg);
        filter: blur(1.5px);
      }
    }
    /* Stagger child reveals so the body composes itself after the card lands. */
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__head,
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__gallery,
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__quote,
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__foot {
      animation: evidenceChildIn .42s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__head    { animation-delay: 80ms; }
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__gallery { animation-delay: 140ms; }
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__quote   { animation-delay: 200ms; }
    .evidence[open]:not([data-closing]) > .evidence__card > .evidence__foot    { animation-delay: 260ms; }
    @keyframes evidenceChildIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  }
  /* Trigger chevron animates in sync with open state. */
  .evidence__chevron { transition: transform .22s cubic-bezier(0.22, 1, 0.36, 1); }

  /* Close affordance — a small red stamp mark, top-right of the card. */
  .evidence__close {
    appearance: none;
    border: 0;
    background: transparent;
    position: absolute;
    top: 6px;
    right: 6px;
    width: 32px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
    color: oklch(0.46 0.16 28);
    cursor: pointer;
    border-radius: 50%;
    transition: background-color .12s ease, color .12s ease, transform .18s ease;
  }
  .evidence__close > span {
    display: block;
    transform: translateY(-1px);
  }
  .evidence__close:hover,
  .evidence__close:focus-visible {
    background: oklch(0.46 0.16 28);
    color: oklch(0.98 0.01 60);
    transform: rotate(90deg);
    outline: none;
  }
  .evidence__close:focus-visible {
    box-shadow: 0 0 0 2px oklch(0.98 0.01 60), 0 0 0 4px oklch(0.46 0.16 28);
  }

  .evidence__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
    margin-bottom: var(--s-3);
    padding-right: 40px; /* room for the close button */
    padding-bottom: var(--s-2);
    border-bottom: 1px dashed oklch(0.62 0.04 60 / 0.55);
  }
  .evidence__kicker {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: 0.7rem;
    font-weight: 900;
    color: oklch(0.46 0.16 28);
  }
  .evidence__ref {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.6rem;
    font-weight: 700;
    color: oklch(0.42 0.03 60 / 0.85);
    text-align: right;
    line-height: 1.3;
  }

  .evidence__quote {
    margin: 0;
    padding: 0 0 0 var(--s-5);
    position: relative;
  }
  .evidence__card--wide .evidence__quote { margin-top: var(--s-4); }
  .evidence__quote-mark {
    position: absolute;
    left: -4px;
    top: -14px;
    font-family: var(--font-display);
    font-size: 2.75rem;
    line-height: 1;
    font-weight: 900;
    color: oklch(0.50 0.18 28);
  }
  .evidence__quote p {
    margin: 0;
    font-style: italic;
    font-weight: 500;
    color: oklch(0.20 0.025 35);
  }

  .evidence__foot {
    margin-top: var(--s-4);
    padding-top: var(--s-3);
    border-top: 1px solid oklch(0.62 0.04 60 / 0.35);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    font-size: 0.78rem;
  }
  .evidence__foot-label {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 800;
    color: oklch(0.46 0.04 50);
    font-size: 0.62rem;
    flex-shrink: 0;
  }
  .evidence__foot-link {
    color: oklch(0.34 0.14 28);
    text-decoration: underline;
    text-decoration-color: oklch(0.68 0.06 50 / 0.7);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    word-break: break-word;
    overflow-wrap: anywhere;
  }
  .evidence__foot-link:hover,
  .evidence__foot-link:focus-visible {
    color: oklch(0.28 0.16 28);
    text-decoration-color: currentColor;
  }

  /* ============ Screenshot gallery ============ */
  .evidence__gallery {
    margin: 0 0 var(--s-3) 0;
    outline: none;
  }
  .evidence__viewport {
    position: relative;
    overflow: hidden;
    background: oklch(0.16 0.01 35);
    border-radius: 2px;
    box-shadow:
      0 0 0 1px oklch(0.52 0.05 60 / 0.25),
      inset 0 0 0 1px oklch(1 0 0 / 0.04);
  }
  .evidence__track {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    width: 100%;
    transition: transform .35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @media (prefers-reduced-motion: reduce) {
    .evidence__track { transition: none; }
  }
  .evidence__slide {
    flex: 0 0 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }
  .evidence__shot-link {
    display: block;
    line-height: 0;
    cursor: zoom-in;
    /* Reserve maximum room for the image inside the card. The minimums (calc with
     * vw/vh) preserve breathing room around the wide card so the screenshot never
     * goes 100% full-bleed. */
    background: oklch(0.12 0.01 35);
  }
  .evidence__shot {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(80vh, calc(100vh - 220px));
    object-fit: contain;
    background: oklch(0.12 0.01 35);
  }
  .evidence__caption {
    margin: 0;
    padding: var(--s-2) var(--s-3);
    font-size: 0.8rem;
    font-style: italic;
    color: oklch(0.88 0.015 60);
    background: oklch(0.20 0.015 35);
    border-top: 1px solid oklch(0.30 0.02 35);
  }

  /* Carousel chrome: arrows overlaid on the viewport, dots below. */
  .evidence__nav {
    appearance: none;
    border: 1px solid oklch(1 0 0 / 0.15);
    background: oklch(0.10 0.01 35 / 0.65);
    color: oklch(0.96 0.01 60);
    width: 40px;
    height: 40px;
    border-radius: 999px;
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    transition:
      background-color .14s ease,
      border-color .14s ease,
      color .14s ease,
      transform .14s ease;
    z-index: 2;
  }
  .evidence__nav--prev { left: 10px; }
  .evidence__nav--next { right: 10px; }
  .evidence__nav:hover,
  .evidence__nav:focus-visible {
    background: oklch(0.50 0.18 28);
    border-color: oklch(0.50 0.18 28);
    color: oklch(0.98 0 0);
    outline: none;
  }
  .evidence__nav--prev:hover,
  .evidence__nav--prev:focus-visible { transform: translateY(-50%) translateX(-2px); }
  .evidence__nav--next:hover,
  .evidence__nav--next:focus-visible { transform: translateY(-50%) translateX(2px); }

  .evidence__counter {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    padding: 4px 10px;
    border-radius: 999px;
    background: oklch(0.10 0.01 35 / 0.7);
    color: oklch(0.94 0.01 60);
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid oklch(1 0 0 / 0.1);
    display: inline-flex;
    align-items: baseline;
    gap: 3px;
    line-height: 1;
  }
  .evidence__counter-sep { opacity: 0.5; }

  .evidence__dots {
    margin: var(--s-3) 0 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }
  .evidence__dot {
    appearance: none;
    border: 0;
    padding: 0;
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: oklch(0.52 0.05 60 / 0.4);
    cursor: pointer;
    transition: background-color .14s ease, transform .14s ease, width .18s ease;
  }
  .evidence__dot:hover { background: oklch(0.50 0.18 28 / 0.7); }
  .evidence__dot[aria-current="true"] {
    background: oklch(0.50 0.18 28);
    width: 22px;
    border-radius: 4px;
  }

  @media (max-width: 720px) {
    .evidence__card {
      width: calc(100vw - 24px);
      max-height: calc(100vh - 24px);
      padding: var(--s-3) var(--s-4);
      font-size: 0.88rem;
    }
    .evidence__card--wide {
      width: calc(100vw - 16px);
      max-height: calc(100vh - 16px);
    }
    .evidence__shot { max-height: min(60vh, calc(100vh - 200px)); }
    .evidence__quote-mark { font-size: 2.2rem; top: -10px; }
    .evidence__nav { width: 34px; height: 34px; font-size: 1.2rem; }
    .evidence__nav--prev { left: 6px; }
    .evidence__nav--next { right: 6px; }
  }
</style>

<script>
  // Evidence behaviour: centered modal popover with backdrop, close button,
  // ESC dismissal, and per-instance carousel.
  //
  // All listeners are document-level and delegated — that way:
  //   1. We never walk `.evidence__card` subtrees at init. They're
  //      `content-visibility: hidden` when closed, so any querySelector dive
  //      into them produces the "Rendering was performed in a subtree hidden
  //      by content-visibility" warning (was firing ~500× on first paint).
  //   2. The gallery DOM (img + carousel chrome) is *lazy-mounted* on the
  //      first <details> open — see `mountGallery`. The shots payload is
  //      carried in `data-shots` JSON, so the SSR'd page ships zero `<img>`
  //      tags for the comparison-table proofs. That kills the request
  //      fan-out on first load (was ~260 requests for hidden screenshots).
  (() => {
    type Shot = { src: string; alt: string; caption?: string };

    const reducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Must match the CSS keyframes (evidenceCardOut).
    const CLOSE_MS = 280;

    const syncBodyLock = () => {
      const anyOpen = !!document.querySelector('details.evidence[open]');
      document.body.classList.toggle('evidence-open', anyOpen);
      document.body.style.overflow = anyOpen ? 'hidden' : '';
    };

    // ---------- Lazy mount: build the gallery DOM on first open ----------
    const mountGallery = (gallery: HTMLElement) => {
      if (gallery.dataset.mounted === 'true') return;
      gallery.dataset.mounted = 'true';

      let shots: Shot[] = [];
      try {
        shots = JSON.parse(gallery.dataset.shots ?? '[]') as Shot[];
      } catch {
        shots = [];
      }
      if (shots.length === 0) return;

      const isCarousel = shots.length > 1;

      const viewport = document.createElement('div');
      viewport.className = 'evidence__viewport';

      const track = document.createElement('ul');
      track.className = 'evidence__track';
      track.setAttribute('role', 'list');

      shots.forEach((shot, i) => {
        const li = document.createElement('li');
        li.className = 'evidence__slide';
        li.dataset.slide = String(i);
        li.setAttribute('aria-hidden', i === 0 ? 'false' : 'true');

        const link = document.createElement('a');
        link.className = 'evidence__shot-link';
        link.href = shot.src;
        link.target = '_blank';
        link.rel = 'noreferrer';
        link.setAttribute('aria-label', `Open ${shot.alt} in a new tab`);

        const img = document.createElement('img');
        img.className = 'evidence__shot';
        img.src = shot.src;
        img.alt = shot.alt;
        // No `loading="lazy"` on purpose: the gallery only mounts after the
        // user actively opens the proof, so we've already decided to pay
        // for the screenshots. Lazy here would split the load across
        // carousel navigations and — under dev's lax caching — refetch each
        // image every time it re-enters the viewport via translateX.
        img.decoding = 'async';
        // First slide warms first; the rest can wait their turn on the same
        // connection but don't need to fight for priority.
        img.setAttribute('fetchpriority', i === 0 ? 'high' : 'low');

        link.appendChild(img);
        li.appendChild(link);

        if (shot.caption) {
          const cap = document.createElement('p');
          cap.className = 'evidence__caption';
          cap.textContent = shot.caption;
          li.appendChild(cap);
        }
        track.appendChild(li);
      });

      viewport.appendChild(track);

      if (isCarousel) {
        const prev = document.createElement('button');
        prev.type = 'button';
        prev.className = 'evidence__nav evidence__nav--prev';
        prev.dataset.dir = '-1';
        prev.setAttribute('aria-label', 'Previous screenshot');
        prev.textContent = '‹';

        const next = document.createElement('button');
        next.type = 'button';
        next.className = 'evidence__nav evidence__nav--next';
        next.dataset.dir = '1';
        next.setAttribute('aria-label', 'Next screenshot');
        next.textContent = '›';

        const counter = document.createElement('div');
        counter.className = 'evidence__counter';
        counter.setAttribute('aria-live', 'polite');
        const cur = document.createElement('span');
        cur.className = 'evidence__counter-current';
        cur.textContent = '1';
        const sep = document.createElement('span');
        sep.className = 'evidence__counter-sep';
        sep.setAttribute('aria-hidden', 'true');
        sep.textContent = '/';
        const tot = document.createElement('span');
        tot.className = 'evidence__counter-total';
        tot.textContent = String(shots.length);
        counter.append(cur, sep, tot);

        viewport.append(prev, next, counter);
      }

      gallery.appendChild(viewport);

      if (isCarousel) {
        const dots = document.createElement('ol');
        dots.className = 'evidence__dots';
        dots.setAttribute('role', 'list');
        shots.forEach((_, i) => {
          const li = document.createElement('li');
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'evidence__dot';
          btn.dataset.goto = String(i);
          btn.setAttribute('aria-label', `Go to screenshot ${i + 1}`);
          btn.setAttribute('aria-current', i === 0 ? 'true' : 'false');
          li.appendChild(btn);
          dots.appendChild(li);
        });
        gallery.appendChild(dots);
      }

      // Stop holding the JSON payload in the attribute once mounted — it's
      // dead weight in the DOM after this point and keeps any future
      // serializer (e.g. clipboard "copy outerHTML") light.
      delete gallery.dataset.shots;
    };

    // ---------- Carousel state lives on the gallery's dataset ----------
    const setCarouselIndex = (gallery: HTMLElement, index: number) => {
      const total = Number(gallery.dataset.count ?? '0');
      if (total <= 0) return;
      const clamped = Math.max(0, Math.min(total - 1, index));
      gallery.dataset.index = String(clamped);
      const track = gallery.querySelector<HTMLElement>('.evidence__track');
      if (track) track.style.transform = `translateX(-${clamped * 100}%)`;
      gallery.querySelectorAll<HTMLElement>('.evidence__slide').forEach((s, i) =>
        s.setAttribute('aria-hidden', i === clamped ? 'false' : 'true'),
      );
      gallery.querySelectorAll<HTMLElement>('.evidence__dot').forEach((d, i) =>
        d.setAttribute('aria-current', i === clamped ? 'true' : 'false'),
      );
      const counter = gallery.querySelector<HTMLElement>('.evidence__counter-current');
      if (counter) counter.textContent = String(clamped + 1);
    };

    const moveCarousel = (gallery: HTMLElement, dir: -1 | 1) => {
      const total = Number(gallery.dataset.count ?? '0');
      if (total <= 1) return;
      const current = Number(gallery.dataset.index ?? '0');
      setCarouselIndex(gallery, (current + dir + total) % total);
    };

    // ---------- Animated close ----------
    const animatedClose = (details: HTMLDetailsElement) => {
      if (!details.open || details.dataset.closing === 'true') return;
      const trigger = details.querySelector<HTMLElement>('.evidence__trigger');
      if (reducedMotion) {
        details.open = false;
        syncBodyLock();
        trigger?.focus({ preventScroll: true });
        return;
      }
      details.dataset.closing = 'true';
      window.setTimeout(() => {
        delete details.dataset.closing;
        details.open = false;
        syncBodyLock();
        trigger?.focus({ preventScroll: true });
      }, CLOSE_MS);
    };

    // ---------- Delegated click handler ----------
    document.addEventListener('click', (ev) => {
      const target = ev.target as HTMLElement | null;
      if (!target) return;

      // 1) Close affordances (× button, backdrop)
      const closer = target.closest<HTMLElement>('[data-close]');
      if (closer) {
        const details = closer.closest<HTMLDetailsElement>('details.evidence');
        if (details) {
          ev.preventDefault();
          animatedClose(details);
          return;
        }
      }

      // 2) Carousel nav arrow
      const nav = target.closest<HTMLButtonElement>('.evidence__nav');
      if (nav) {
        const gallery = nav.closest<HTMLElement>('.evidence__gallery--carousel');
        if (gallery) {
          ev.preventDefault();
          ev.stopPropagation();
          const dir = Number(nav.dataset.dir ?? '1');
          moveCarousel(gallery, dir < 0 ? -1 : 1);
          return;
        }
      }

      // 3) Carousel dot
      const dot = target.closest<HTMLButtonElement>('.evidence__dot');
      if (dot) {
        const gallery = dot.closest<HTMLElement>('.evidence__gallery--carousel');
        if (gallery) {
          ev.preventDefault();
          ev.stopPropagation();
          const goto = Number(dot.dataset.goto ?? '0');
          if (Number.isFinite(goto)) setCarouselIndex(gallery, goto);
          return;
        }
      }

      // 4) Summary click while already open → animated close instead of the
      //    native snap-shut. The native toggle still fires after this handler
      //    in the close case, but `[data-closing]` keeps the card mounted
      //    long enough for the keyframes to play.
      const trigger = target.closest<HTMLElement>('.evidence__trigger');
      if (trigger) {
        const details = trigger.closest<HTMLDetailsElement>('details.evidence');
        if (details && (details.open || details.dataset.closing === 'true')) {
          ev.preventDefault();
          if (details.dataset.closing !== 'true') animatedClose(details);
        }
      }
    });

    // ---------- Delegated keyboard handler ----------
    document.addEventListener('keydown', (ev) => {
      if (ev.key === 'Escape') {
        const openOne = document.querySelector<HTMLDetailsElement>('details.evidence[open]');
        if (!openOne) return;
        ev.preventDefault();
        animatedClose(openOne);
        return;
      }
      if (ev.key === 'ArrowLeft' || ev.key === 'ArrowRight') {
        const openOne = document.querySelector<HTMLDetailsElement>('details.evidence[open]');
        if (!openOne) return;
        const gallery = openOne.querySelector<HTMLElement>('.evidence__gallery--carousel');
        if (!gallery) return;
        ev.preventDefault();
        moveCarousel(gallery, ev.key === 'ArrowLeft' ? -1 : 1);
      }
    });

    // ---------- Toggle: mount on first open, sync body lock, focus close ----
    // `toggle` events don't bubble in every browser yet, so we listen during
    // the capture phase to delegate from `document`. Capture-phase listeners
    // see non-bubbling events on the path to target.
    document.addEventListener(
      'toggle',
      (ev) => {
        const details = ev.target as HTMLDetailsElement | null;
        if (!(details instanceof HTMLDetailsElement)) return;
        if (!details.classList.contains('evidence')) return;
        syncBodyLock();
        if (details.open && details.dataset.closing !== 'true') {
          const gallery = details.querySelector<HTMLElement>('.evidence__gallery');
          if (gallery) mountGallery(gallery);
          const closeBtn = details.querySelector<HTMLButtonElement>('.evidence__close');
          requestAnimationFrame(() => closeBtn?.focus({ preventScroll: true }));
        }
      },
      true,
    );
  })();
</script>
